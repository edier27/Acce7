  XLSX.utils.book_append_sheet(wb,wsMov,'Movimientos');
  // Hoja 3: Liquidaciones
  let liqData=[['ID','Fecha','Cliente','Nº Productos','Valor Liquidado','Notas']];
  db.liquidaciones.forEach(l=>{
    let c=db.clientes.find(x=>x.id===l.clienteId);
    liqData.push([l.id,l.fecha,c?c.nombre:'—',l.productos,l.valor,l.notas||'']);
  });
  let wsLiq=XLSX.utils.aoa_to_sheet(liqData);
  XLSX.utils.book_append_sheet(wb,wsLiq,'Liquidaciones');
  XLSX.writeFile(wb,`eben-ezer-${today()}.xlsx`);
  toast('📊 Excel exportado correctamente');
}

