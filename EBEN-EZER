function renderProdDia(){
  let mesInput=document.getElementById('pd-mes-filter');
  let mesVal=mesInput.value;
  // Filter movimientos by month
  let movs=db.movimientos.filter(m=>{
    if(!mesVal)return true;
    return m.fecha.startsWith(mesVal);
  });
  // Group by date
  let byDay={};
  movs.forEach(m=>{
    if(!byDay[m.fecha])byDay[m.fecha]=[];
    byDay[m.fecha].push(m);
  });
  let dias=Object.keys(byDay).sort().reverse();
  // Stats — Valor pendiente son solo los no pagados para coincidir con dashboard
  let totalItems=movs.length;
  let movsPend=movs.filter(m=>!m.pagado);
  let totalPendiente=movsPend.reduce((s,m)=>s+m.valorUnit*m.cantidad,0);
  let totalBruto=movs.reduce((s,m)=>s+m.valorUnit*m.cantidad,0);
  let diasActivos=dias.length;
  document.getElementById('pd-stats').innerHTML=`
    <div class="stat-card s-blue"><div class="bg-icon">📦</div><div class="stat-label">Total Productos</div><div class="stat-value">${totalItems}</div><div class="stat-sub">${movsPend.length} pendientes de pago</div></div>
    <div class="stat-card s-gray"><div class="bg-icon">📅</div><div class="stat-label">Días con Actividad</div><div class="stat-value">${diasActivos}</div><div class="stat-sub">días con movimientos</div></div>
    <div class="stat-card s-red"><div class="bg-icon">💰</div><div class="stat-label">Deuda Pendiente</div><div class="stat-value" style="font-size:19px;padding-top:4px">${fmt(totalPendiente)}</div><div class="stat-sub">Total registrado: ${fmt(totalBruto)}</div></div>`;
  if(!dias.length){
    document.getElementById('pd-content').innerHTML=`<div class="empty-state">Sin productos registrados${mesVal?' para este mes':''}</div>`;
    return;
  }
  let html=dias.map(fecha=>{
    let items=byDay[fecha];
    let total=items.reduce((s,m)=>s+m.valorUnit*m.cantidad,0);
    let fechaFmt=new Date(fecha+'T12:00:00').toLocaleDateString('es-CO',{weekday:'long',day:'2-digit',month:'long',year:'numeric'});
    let rows=items.map(m=>{
      let c=db.clientes.find(x=>x.id===m.clienteId);
      return`<tr>
        <td>${c?`<span class="avatar" style="background:${c.color}22;color:${c.color};font-size:10px">${ini(c.nombre)}</span>${c.nombre}`:'—'}</td>
        <td><strong>${m.producto}</strong></td>
        <td style="color:var(--muted)">${m.cantidad}</td>
        <td style="color:var(--muted)">${fmt(m.valorUnit)}</td>
        <td style="font-weight:700;color:var(--accent)">${fmt(m.valorUnit*m.cantidad)}</td>
        <td><span class="badge ${m.pagado?'badge-green':'badge-red'}">${m.pagado?'✓ Pagado':'Pendiente'}</span></td>
      </tr>`;
    }).join('');
    return`<div style="margin-bottom:18px;">
      <div style="display:flex;align-items:center;justify-content:space-between;margin-bottom:8px;">
        <div style="font-family:var(--font-head);font-size:16px;font-weight:700;color:var(--text);text-transform:capitalize;">${fechaFmt}</div>
        <div style="font-weight:700;color:var(--accent);font-family:var(--font-head);font-size:15px;">${fmt(total)} &nbsp;<span style="font-size:11px;color:var(--muted);font-family:var(--font-body);font-weight:400">${items.length} producto${items.length!==1?'s':''}</span></div>
      </div>
      <div class="table-wrap" style="border:1px solid var(--border2);border-radius:10px;overflow:hidden;">
        <table>
          <thead><tr><th>Cliente</th><th>Producto</th><th>Cant.</th><th>Val. Unit.</th><th>Total</th><th>Estado</th></tr></thead>
          <tbody>${rows}</tbody>
        </table>
      </div>
    </div>`;
  }).join('<div class="divider"></div>');
  document.getElementById('pd-content').innerHTML=html;
}

