  let filtroEst=document.getElementById('hist-filter')?.value||'todos';
  let filtroCli=document.getElementById('hist-cliente-filter')?.value||'';
  let movs=[...db.movimientos].sort((a,b)=>new Date(b.fecha)-new Date(a.fecha));
  if(filtroCli)movs=movs.filter(m=>m.clienteId===parseInt(filtroCli));
  if(filtroEst==='pendiente')movs=movs.filter(m=>!m.pagado);
  else if(filtroEst==='pagado')movs=movs.filter(m=>m.pagado);
  if(busq){movs=movs.filter(m=>{let c=db.clientes.find(x=>x.id===m.clienteId);return(c&&c.nombre.toLowerCase().includes(busq))||m.producto.toLowerCase().includes(busq);});}
  let resDiv=document.getElementById('hist-resumen');
  if(filtroCli||busq){
    let cliRes=filtroCli?db.clientes.find(x=>x.id===parseInt(filtroCli)):null;
    let totalMovs=movs.reduce((s,m)=>s+m.valorUnit*m.cantidad,0);
    let pendMovs=movs.filter(m=>!m.pagado).reduce((s,m)=>s+m.valorUnit*m.cantidad,0);
    resDiv.style.display='block';
    resDiv.innerHTML=`<strong>${cliRes?cliRes.nombre:'Resultados filtrados'}</strong> — ${movs.length} movimiento${movs.length!==1?'s':''} &nbsp;·&nbsp; Total: <strong style="color:var(--accent)">${fmt(totalMovs)}</strong> &nbsp;·&nbsp; Pendiente: <strong style="color:var(--red)">${fmt(pendMovs)}</strong>`;
  } else {resDiv.style.display='none';}
  let rows=movs.map(m=>{
    let c=db.clientes.find(x=>x.id===m.clienteId);
    let esCuenta=m.tipo==='cuenta';
    return`<tr>
      <td style="color:var(--muted)">${fmtFechaHora(m.fecha)}</td>
      <td>${c?`<span class="avatar" style="background:${c.color}22;color:${c.color};font-size:10px">${ini(c.nombre)}</span>${c.nombre}`:'—'}</td>
