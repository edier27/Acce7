  let raw=localStorage.getItem('te4_db');
  let tamano=raw?Math.round(raw.length/1024)+' KB':'0 KB';
  let ultimoGuardado=ts?new Date(parseInt(ts)).toLocaleString('es-CO'):'Nunca';
  let parsed=null;try{parsed=raw?JSON.parse(raw):null;}catch(e){}
  let clientes=parsed?.clientes?.length??0;
  let movs=parsed?.movimientos?.length??0;
  let liq=parsed?.liquidaciones?.length??0;

  // Test de escritura
  let puedeEscribir=false;
