  let mSel=document.getElementById('liq-mes-filter');
  let curMes=mSel.value;
  mSel.innerHTML='<option value="">Todos los meses</option>'+meses.map(m=>{
    let d=new Date(m+'-01');return`<option value="${m}">${d.toLocaleDateString('es-CO',{month:'long',year:'numeric'})}</option>`;
  }).join('');
  mSel.value=curMes;
  let busq=(document.getElementById('liq-search')?.value||'').toLowerCase();
  let filtroMes=document.getElementById('liq-mes-filter')?.value||'';
  let liqs=[...db.liquidaciones].sort((a,b)=>new Date(b.fecha)-new Date(a.fecha));
  if(filtroMes)liqs=liqs.filter(l=>l.fecha.startsWith(filtroMes));
  if(busq)liqs=liqs.filter(l=>{let c=db.clientes.find(x=>x.id===l.clienteId);return c&&c.nombre.toLowerCase().includes(busq);});

  let rows=liqs.map(l=>{
    let c=db.clientes.find(x=>x.id===l.clienteId);
    let fechaBase=l.fecha.includes('T')?l.fecha:l.fecha+'T12:00:00';let fecha=new Date(fechaBase).toLocaleDateString('es-CO',{day:'2-digit',month:'short',year:'numeric'})+(l.fecha.includes('T')?' '+l.fecha.split('T')[1].slice(0,5):'');
    let det=l.detalle&&l.detalle.length?l.detalle:[];
    let resumenDet=det.length?det.slice(0,2).map(p=>`<span style="font-size:11px;background:var(--accent-light);color:var(--accent);border-radius:4px;padding:2px 6px;margin:1px;display:inline-block;">${p.producto}</span>`).join('')+(det.length>2?`<span style="font-size:11px;color:var(--muted)"> +${det.length-2} más</span>`:''): `<span style="color:var(--muted);font-size:12px">${l.productos} producto${l.productos!==1?'s':''}</span>`;
    return`<tr>
      <td style="color:var(--muted);font-weight:600">${fecha}</td>
      <td>${c?`<span class="avatar" style="background:${c.color}22;color:${c.color};font-size:10px">${ini(c.nombre)}</span><strong>${c.nombre}</strong>`:'—'}</td>
      <td>${resumenDet}</td>
      <td style="font-weight:800;font-family:var(--font-head);font-size:15px;color:var(--green)">${fmt(l.valor)}<br><span class="badge ${l.tipo==='abono'?'badge-abono':'badge-green'}" style="font-size:10px;">${l.tipo==='abono'?'Abono':'Pago Total'}</span></td>
      <td>
        <button class="btn btn-xs btn-ghost" onclick="verDetalleLiq(${l.id})">🔍 Ver qué pagó</button>
      </td>
      <td style="display:flex;gap:4px;">
        <button class="btn btn-xs btn-warning" onclick="editarLiq(${l.id})">✏️ Editar</button>
        <button class="btn btn-xs btn-danger" onclick="eliminarLiq(${l.id})">🗑️ Eliminar</button>
      </td></tr>`;
  }).join('');
  document.getElementById('liq-table').innerHTML=rows||`<tr><td colspan="6"><div class="empty-state">No hay liquidaciones registradas aún</div></td></tr>`;
}

// Ver detalle de lo que se pagó en una liquidación
function verDetalleLiq(id){
  let l=db.liquidaciones.find(x=>x.id===id);
  if(!l)return;
  let c=db.clientes.find(x=>x.id===l.clienteId);
