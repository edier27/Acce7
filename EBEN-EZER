  let cliData=[['ID','Nombre','Teléfono','Dirección','Deuda Total','Ítems Pendientes','Estado']];
  db.clientes.forEach(c=>{
    let d=deuda(c.id),mv=activos(c.id).length;
    cliData.push([c.id,c.nombre,c.telefono,c.direccion,d,mv,d>0?'Debe':'Al día']);
  });
  let wsCli=XLSX.utils.aoa_to_sheet(cliData);
  XLSX.utils.book_append_sheet(wb,wsCli,'Clientes');
  // Hoja 2: Movimientos
  let movData=[['ID','Fecha','Cliente','Producto','Cantidad','Valor Unitario','Total','Estado']];
  db.movimientos.forEach(m=>{
    let c=db.clientes.find(x=>x.id===m.clienteId);
    movData.push([m.id,m.fecha,c?c.nombre:'—',m.producto,m.cantidad,m.valorUnit,m.valorUnit*m.cantidad,m.pagado?'Pagado':'Pendiente']);
  });
