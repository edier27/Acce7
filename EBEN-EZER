let qsSelectedId=null;
function busquedaRapida(v){
  let res=document.getElementById('qs-results');
  let btnVer=document.getElementById('qs-btn-ver');
  if(!v||v.length<2){res.style.display='none';btnVer.style.display='none';qsSelectedId=null;return;}
  let matches=db.clientes.filter(c=>c.nombre.toLowerCase().includes(v.toLowerCase())||c.telefono.includes(v));
  if(!matches.length){res.innerHTML=`<div class="qs-result-item" style="color:var(--muted);">Sin resultados para "${v}"</div>`;res.style.display='block';return;}
  res.innerHTML=matches.map(c=>{
    let d=deuda(c.id);
    return`<div class="qs-result-item" onclick="qsSeleccionar(${c.id})">
      <div class="avatar" style="background:${c.color}22;color:${c.color};font-size:10px;margin:0;flex-shrink:0">${ini(c.nombre)}</div>
      <div style="flex:1"><div class="qs-result-name">${c.nombre}</div><div class="qs-result-meta">📞 ${c.telefono} &nbsp;·&nbsp; ${activos(c.id).length} ítem${activos(c.id).length!==1?'s':''} pendientes</div></div>
      <div class="qs-result-debt" style="color:${d>0?'var(--accent)':'var(--green)'}">${fmt(d)}</div>
    </div>`;
  }).join('');
  res.style.display='block';
}
function qsSeleccionar(id){
  let c=db.clientes.find(x=>x.id===id);
  if(!c)return;
  qsSelectedId=id;
  document.getElementById('qs-input').value=c.nombre;
  document.getElementById('qs-results').style.display='none';
  document.getElementById('qs-btn-ver').style.display='inline-flex';
  // Abrir directamente la pantalla de deuda
  verDetalle(id);
}
function qsVerDetalle(){if(qsSelectedId)verDetalle(qsSelectedId);}
function qsKey(e){
  if(e.key==='Escape'){document.getElementById('qs-results').style.display='none';}
  if(e.key==='Enter'&&qsSelectedId){verDetalle(qsSelectedId);}
}
document.addEventListener('click',function(e){
