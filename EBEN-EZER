function confirmarAbonoParcial(id,total){
  let abono=parseFloat(document.getElementById('liq-abono-val')?.value)||0;
  if(!abono||abono<=0){toast('⚠️ Ingresa el valor del abono','info');return;}
  if(abono>=total){if(!confirm('El abono cubre o supera la deuda total. ¿Deseas liquidar completamente?'))return;confirmarPago(id,total,activos(id).length);return;}
  let c=db.clientes.find(x=>x.id===id);
  // Descontar el abono de los movimientos activos, del más antiguo al más reciente
  let movsPend=db.movimientos.filter(m=>m.clienteId===id&&!m.pagado).sort((a,b)=>new Date(a.fecha)-new Date(b.fecha));
  let restante=abono;
  let detalle=[];
  for(let m of movsPend){
    if(restante<=0)break;
    let subtotal=m.valorUnit*m.cantidad;
    if(restante>=subtotal){
      // Este movimiento queda saldado
      m.pagado=true;
      detalle.push({producto:m.producto,cantidad:m.cantidad,valorUnit:m.valorUnit,fecha:m.fecha});
      restante-=subtotal;
    } else {
      // Abono parcial a este movimiento: reducimos el valorUnit proporcionalmente
      let cantPagada=restante/m.valorUnit;
      if(cantPagada>=m.cantidad){
        m.pagado=true;
        detalle.push({producto:m.producto,cantidad:m.cantidad,valorUnit:m.valorUnit,fecha:m.fecha});
      } else {
        // Dividir en dos: la parte pagada y el saldo restante
        let cantPag=Math.floor(cantPagada);
        let pagoParcial=restante;
        // Reducir el valor unitario del movimiento existente para reflejar el saldo
        let nuevoTotal=subtotal-pagoParcial;
        m.valorUnit=nuevoTotal/m.cantidad;
        detalle.push({producto:m.producto+' (abono)',cantidad:m.cantidad,valorUnit:pagoParcial/m.cantidad,fecha:m.fecha});
      }
      restante=0;
    }
  }
  let saldo=deuda(id);
  db.liquidaciones.push({id:db.nli++,clienteId:id,fecha:nowDateTime(),valor:abono,productos:detalle.length,detalle,notas:'Abono parcial',tipo:'abono'});
  save(`Abono parcial de ${c.nombre}: ${fmt(abono)}`);
  closeModal('m-det');
  refreshAll();
  toast(`✓ Abono de ${fmt(abono)} registrado para ${c.nombre} — Saldo: ${fmt(saldo)}`);
  // WA: sin número Nequi en comprobante de abono
  let tel=formatearTelefono(c.telefono);
  if(tel){
    let msg=`*COMPROBANTE DE ABONO*\nTienda Eben-ezer\n\nHola ${c.nombre.split(' ')[0]}, confirmamos tu abono:\n\n*Abono recibido:* ${fmt(abono)}\n*Saldo pendiente:* ${fmt(saldo)}\n*Fecha:* ${new Date().toLocaleDateString('es-CO',{day:'2-digit',month:'long',year:'numeric'})} ${new Date().toLocaleTimeString('es-CO',{hour:'2-digit',minute:'2-digit'})}\n\n🏪 _Gracias por tu pago — Tienda Eben-ezer_`;
    toastWA('✓ Abono registrado — ¿enviar comprobante?','https://wa.me/'+tel+'?text='+encodeURIComponent(msg));
  }
}

