let barC,dghC;
function renderCharts(){
  let sorted=db.clientes.slice().sort((a,b)=>deuda(b.id)-deuda(a.id)).slice(0,8);
  let labels=sorted.map(c=>c.nombre.split(' ')[0]);
  let vals=sorted.map(c=>deuda(c.id));
  let cols=sorted.map(c=>c.color+'bb');
  let borders=sorted.map(c=>c.color);
  if(barC)barC.destroy();
  barC=new Chart(document.getElementById('chart-bar'),{type:'bar',data:{labels,datasets:[{data:vals,backgroundColor:cols,borderColor:borders,borderWidth:1.5,borderRadius:7,borderSkipped:false}]},options:{responsive:true,plugins:{legend:{display:false},tooltip:{callbacks:{label:ctx=>fmt(ctx.raw)}}},scales:{x:{grid:{color:'rgba(0,0,0,.04)'},ticks:{color:'#7a96b5',font:{family:'Plus Jakarta Sans',size:11}}},y:{grid:{color:'rgba(0,0,0,.04)'},ticks:{color:'#7a96b5',callback:v=>fmt(v),font:{family:'Plus Jakarta Sans',size:11}}}}}});
  if(dghC)dghC.destroy();
  dghC=new Chart(document.getElementById('chart-doughnut'),{type:'doughnut',data:{labels,datasets:[{data:vals,backgroundColor:cols,borderColor:'#fff',borderWidth:3}]},options:{responsive:true,cutout:'62%',plugins:{legend:{position:'right',labels:{color:'#3b5a82',font:{family:'Plus Jakarta Sans',size:11},padding:9,boxWidth:11,boxHeight:11}},tooltip:{callbacks:{label:ctx=>ctx.label+': '+fmt(ctx.raw)}}}}});
}

