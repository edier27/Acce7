  document.getElementById('reg-general-result').innerHTML=`
    <div class="cli-found-card" style="margin-bottom:12px;">
      <div class="avatar" style="background:${c.color}22;color:${c.color};font-size:12px;width:42px;height:42px;">${ini(c.nombre)}</div>
      <div><div class="cfc-name">${c.nombre}</div><div class="cfc-meta">📞 ${c.telefono}</div></div>
      <div class="cfc-deuda" style="color:${d>0?'var(--accent)':'var(--green)'}">${fmt(d)}</div>
    </div>
    ${movs.length?`<div class="slabel">Pendiente (${movs.length})</div><div class="product-list-modal">${items}</div>`:`<div style='color:var(--green);text-align:center;padding:12px;font-size:14px;'>✅ Sin deuda pendiente</div>${ultimoPago(id)?`<div style='color:var(--muted);text-align:center;font-size:12px;padding:4px 0 8px;'>💚 Último pago: ${fmtFechaHora(ultimoPago(id))}</div>`:''}`}
    <div class="form-actions">
      <button class="btn btn-ghost btn-sm" onclick="verDetalle(${id})">📋 Ver Cuenta Completa</button>
      ${d>0?`<button class="btn btn-success btn-sm" onclick="liquidar(${id})">✓ Liquidar</button>`:''}
    </div>`;
}

