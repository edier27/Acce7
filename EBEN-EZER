<script>
// ═══════════════════════════════════════════
// DB + PERSISTENCIA + HISTORIAL UNDO/REDO
// ═══════════════════════════════════════════
let db={clientes:[],movimientos:[],liquidaciones:[],nci:1,nmi:1,nli:1};

// Historial: pila de estados para deshacer/rehacer
let historial=[];
let historialIdx=-1;
const MAX_HIST=50;

function snapshot(desc=''){
  // Al hacer un cambio nuevo, eliminamos todo lo que estaba "adelante"
  if(historialIdx<historial.length-1){
    historial=historial.slice(0,historialIdx+1);
  }
  historial.push({estado:JSON.stringify(db),desc:desc||'Cambio',ts:Date.now()});
  if(historial.length>MAX_HIST)historial.shift();
  historialIdx=historial.length-1;
  _saveHistorial();
}

function undo(){
  if(historialIdx<=0){toast('⚠️ No hay más cambios anteriores','info');return;}
  historialIdx--;
  db=JSON.parse(historial[historialIdx].estado);
  _migrateDb();
  localStorage.setItem('te4_db',JSON.stringify(db));
  _saveHistorial();
  refreshAll();
  let desc=historial[historialIdx+1]?.desc||'';
  toast(`↩️ Deshecho: ${desc}`);
}

function redo(){
  if(historialIdx>=historial.length-1){toast('⚠️ No hay más cambios por rehacer','info');return;}
  historialIdx++;
  db=JSON.parse(historial[historialIdx].estado);
  _migrateDb();
  localStorage.setItem('te4_db',JSON.stringify(db));
  _saveHistorial();
  refreshAll();
  let desc=historial[historialIdx]?.desc||'';
  toast(`↪️ Rehecho: ${desc}`);
}

function _updateUndoRedoBtns(){
  let btnU=document.getElementById('btn-undo');
  let btnR=document.getElementById('btn-redo');
  if(btnU){
    btnU.disabled=historialIdx<=0;
    btnU.style.opacity=historialIdx<=0?'0.4':'1';
    let prev=historialIdx>0?historial[historialIdx-1]?.desc:'';
    btnU.title=historialIdx>0?`Deshacer: ${historial[historialIdx].desc}`:'Sin cambios anteriores';
  }
  if(btnR){
    btnR.disabled=historialIdx>=historial.length-1;
    btnR.style.opacity=historialIdx>=historial.length-1?'0.4':'1';
    btnR.title=historialIdx<historial.length-1?`Rehacer: ${historial[historialIdx+1]?.desc}`:'Sin cambios por rehacer';
  }
}

function _saveHistorial(){
  try{localStorage.setItem('te4_hist',JSON.stringify({historial,historialIdx}));}catch(e){}
}

function _loadHistorial(){
  try{
    let h=localStorage.getItem('te4_hist');
    if(h){let p=JSON.parse(h);historial=p.historial||[];historialIdx=p.historialIdx??-1;}
  }catch(e){}
}

function _migrateDb(){
  if(!db.liquidaciones)db.liquidaciones=[];
  if(!db.nli)db.nli=1;
  db.liquidaciones.forEach(l=>{if(!l.detalle)l.detalle=[];});
}

function save(desc=''){
  try{
    snapshot(desc);
    const payload=JSON.stringify(db);
    localStorage.setItem('te4_db',payload);
    localStorage.setItem('te4_db_ts',Date.now().toString());
    // Guardar en Firebase (nube automática)
    if(window.__ebeFirebaseOK && window.__ebeDB){
      window.__ebeDB.set({
        appData: payload,
        updatedAt: new Date().toISOString()
      }).catch(function(e){ console.warn('Error Firebase Eben-ezer:', e); });
    }
    // Indicador visual de guardado
    let el=document.getElementById('save-status');
    if(el){
      el.textContent='✅ Guardado';
      el.style.color='var(--accent)';
      clearTimeout(el._t);
      el._t=setTimeout(()=>{el.textContent='💾 Datos guardados';el.style.color='';},1800);
    }
    _updateTopbarDeuda();
  }catch(e){
    let el=document.getElementById('save-status');
    if(el){el.textContent='⚠️ Error al guardar';el.style.color='var(--red)';}
    console.error('Error guardando:',e);
  }
}
function _updateTopbarDeuda(){
  let td=db.clientes.reduce((s,c)=>s+deuda(c.id),0);
  let el=document.getElementById('topbar-deuda-total');
  if(el && td>0) el.textContent='💰 Total en fiados: '+fmt(td);
  else if(el) el.textContent='Sistema de Fiados';
}
// Cargar datos frescos desde Firebase (asíncrono)
function _loadFromFirebase(){
  if(!window.__ebeFirebaseOK || !window.__ebeDB) return;
  window.__ebeDB.get().then(function(doc){
    if(doc.exists && doc.data().appData){
      try{
        const fbData = JSON.parse(doc.data().appData);
        const fbTs = doc.data().updatedAt ? new Date(doc.data().updatedAt).getTime() : 0;
        const localTs = parseInt(localStorage.getItem('te4_db_ts')||'0');
        // Solo actualizar si Firebase tiene datos más recientes
        if(fbTs > localTs && fbData && Array.isArray(fbData.clientes)){
          db = fbData;
          _migrateDb();
          localStorage.setItem('te4_db', JSON.stringify(fbData));
          localStorage.setItem('te4_db_ts', fbTs.toString());
          refreshAll();
          console.log('✅ Datos actualizados desde Firebase');
        }
      }catch(e){ console.warn('Error procesando Firebase:', e); }
    } else if(!doc.exists) {
      // Primera vez: subir datos locales a Firebase
      save('Primera sincronización con Firebase');
    }
  }).catch(function(e){ console.warn('Error leyendo Firebase:', e); });
}

function load(){
  _loadHistorial();
  // 1. Intentar localStorage con clave principal
  try{
    let r=localStorage.getItem('te4_db');
    let ts=localStorage.getItem('te4_db_ts');
    if(r){
      let parsed=JSON.parse(r);
      if(parsed && Array.isArray(parsed.clientes)){
        db=parsed;
        _migrateDb();
        console.log('[DB] Cargado desde localStorage — ts:',ts?new Date(parseInt(ts)).toLocaleString():'—',`(${db.clientes.length} clientes, ${db.movimientos.length} movs)`);
        // Cargar datos frescos de Firebase en segundo plano
        _loadFromFirebase();
        return true;
      }
    }
  }catch(e){console.warn('[DB] Error leyendo te4_db:',e);}
  // 2. Intentar claves antiguas
  try{
    let keys=['te4_hist','tc3_db','tc2_db'];
    for(let k of keys){
      if(k==='te4_hist') continue;
      let r2=localStorage.getItem(k);
      if(r2){
        let old=JSON.parse(r2);
        if(old && Array.isArray(old.clientes)){
          db.clientes=old.clientes||[];
          db.movimientos=old.movimientos||[];
          db.nci=old.nci||db.clientes.length+1;
          db.nmi=old.nmi||db.movimientos.length+1;
          db.liquidaciones=(old.liquidaciones||[]).map(l=>({...l,detalle:l.detalle||[]}));
          db.nli=old.nli||1;
          _migrateDb();
          save('Migración de datos');
          console.log('[DB] Migrado desde',k);
          return true;
        }
      }
    }
  }catch(e){console.warn('[DB] Error en migración:',e);}
  // 3. No hay datos — se llamará seed()
  console.log('[DB] Sin datos previos — iniciando con datos de ejemplo');
  return false;
}

// ═══════════════════════════════════════════
// SEED
// ═══════════════════════════════════════════
function seed(){
  const CC=['#2563a8','#1a7a4a','#6b4c9a','#4a7fb5','#2980b9','#c0392b','#16a085'];
  const CL=[{nombre:'María García',telefono:'310 555 1234',direccion:'Calle 10 # 5-20'},
    {nombre:'Juan Pérez',telefono:'311 222 4567',direccion:'Carrera 7 # 12-3'},
    {nombre:'Lucía Martínez',telefono:'315 888 9000',direccion:'Av. 15 # 8-90'},
    {nombre:'Carlos Ruiz',telefono:'318 444 7777',direccion:'Calle 22 # 1-15'},
    {nombre:'Ana Torres',telefono:'314 666 3210',direccion:'Carrera 3 # 5-6'}];
  const PR=['Arroz 5kg','Aceite 1L','Azúcar 2kg','Café 500g','Leche 1L','Panela 1kg','Sal 1kg','Harina 2kg','Jabón x3','Pasta x2','Atún x2','Frijoles 1kg'];
  CL.forEach((c,i)=>db.clientes.push({id:db.nci++,...c,color:CC[i%CC.length]}));
  let now=new Date();
  db.clientes.forEach(c=>{
    let n=3+Math.floor(Math.random()*5);
    for(let i=0;i<n;i++){
      let d=new Date(now);d.setDate(d.getDate()-Math.floor(Math.random()*60));
      db.movimientos.push({id:db.nmi++,clienteId:c.id,producto:PR[Math.floor(Math.random()*PR.length)],cantidad:1+Math.floor(Math.random()*4),valorUnit:(1+Math.floor(Math.random()*15))*2000,fecha:d.toISOString().split('T')[0],pagado:false,tipo:'individual'});
    }
  });
  save('Estado inicial');
}

// ═══════════════════════════════════════════
// HELPERS
// ═══════════════════════════════════════════
const fmt=n=>'$'+Number(n).toLocaleString('es-CO');
const ini=n=>n.split(' ').slice(0,2).map(w=>w[0]).join('').toUpperCase();
const deuda=id=>db.movimientos.filter(m=>m.clienteId===id&&!m.pagado).reduce((s,m)=>s+m.valorUnit*m.cantidad,0);
const activos=id=>db.movimientos.filter(m=>m.clienteId===id&&!m.pagado).sort((a,b)=>new Date(a.fecha)-new Date(b.fecha));
const ulti=id=>{let ms=db.movimientos.filter(m=>m.clienteId===id);return ms.length?ms.sort((a,b)=>new Date(b.fecha)-new Date(a.fecha))[0].fecha:'—';}
const today=()=>new Date().toISOString().split('T')[0];
const nowDateTime=()=>{let n=new Date();let pad=x=>String(x).padStart(2,'0');return n.getFullYear()+'-'+pad(n.getMonth()+1)+'-'+pad(n.getDate())+'T'+pad(n.getHours())+':'+pad(n.getMinutes());};
const fmtFechaHora=v=>{if(!v)return'—';if(v.includes('T')){let[fd,ft]=v.split('T');let[y,mo,d]=fd.split('-');return d+'/'+mo+'/'+y+' '+ft;}let[y,mo,d]=v.split('-');return d+'/'+mo+'/'+y;};
const fmtFechaSolo=v=>{if(!v)return'—';let f=v.includes('T')?v.split('T')[0]:v;let[y,mo,d]=f.split('-');return d+'/'+mo+'/'+y;};
const ultimoPago=id=>{let ls=db.liquidaciones.filter(l=>l.clienteId===id);if(!ls.length)return null;ls.sort((a,b)=>new Date(b.fecha)-new Date(a.fecha));return ls[0].fecha;};
function curPage(){
