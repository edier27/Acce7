// ENVIAR COBRO POR WHATSAPP
// ═══════════════════════════════════════════
function formatearTelefono(tel){
  if(!tel||tel==='—')return null;
  let digits=tel.replace(/\D/g,'');
  if(!digits)return null;
  // Si empieza con 57 (Colombia) y tiene 12 dígitos, ok
  if(digits.startsWith('57')&&digits.length>=11)return digits;
  // Si tiene 10 dígitos (número local Colombia), agrega 57
  if(digits.length===10)return '57'+digits;
  // Si tiene 7 (sin área), no podemos saber
  return digits.length>=7?'57'+digits:null;
}

function enviarWhatsApp(clienteId, modo){
  // modo: 'deuda' = productos pendientes | 'liquidar' = cuenta a cobrar
  let c=db.clientes.find(x=>x.id===clienteId);
  if(!c)return;
  let tel=formatearTelefono(c.telefono);
  if(!tel){
    toast('⚠️ Este cliente no tiene número de teléfono registrado','info');
    return;
  }
  let movs=activos(clienteId);
  let total=deuda(clienteId);
  if(!movs.length){toast('ℹ️ Este cliente no tiene productos pendientes','info');return;}

  // Construir lista de productos
  let lista=movs.map(m=>{
    let subtotal=m.valorUnit*m.cantidad;
    let linea=`• ${m.producto}`;
    if(m.cantidad>1) linea+=` ×${m.cantidad}`;
    linea+=` = ${fmt(subtotal)}`;
    return linea;
  }).join('\n');

  let fecha=new Date().toLocaleDateString('es-CO',{day:'2-digit',month:'long',year:'numeric'});
  let encabezado=modo==='liquidar'
    ? `Hola ${c.nombre.split(' ')[0]}, te comparto el resumen de tu cuenta para proceder con el cobro:`
    : `Hola ${c.nombre.split(' ')[0]}, te enviamos el resumen de tu cuenta en *Tienda Eben-ezer*:`;

  // Nequi info en el mensaje de texto
  let nequiCfg=JSON.parse(localStorage.getItem('te4_nequi')||'{}');
  let nequiMsg='';
  if(nequiCfg.numero){
    nequiMsg=`\n\n*PAGAR POR NEQUI:*\n*Número:* ${nequiCfg.numero}\n*Cuenta:* ${nequiCfg.nombre||'Tienda Eben-ezer'}`;
  }

  let mensaje=
`${encabezado}

*PRODUCTOS PENDIENTES:*
${lista}

*TOTAL A PAGAR: ${fmt(total)}*${nequiMsg}

_Fecha: ${fecha}_
_Tienda Eben-ezer_

_Gracias por tu preferencia_`;

  let url=`https://wa.me/${tel}?text=${encodeURIComponent(mensaje)}`;

  // Si hay QR configurado, mostrar panel para que lo envíe manualmente
  if(nequiCfg.qrImg){
    _mostrarPanelQR(url, nequiCfg);
  } else {
    window.open(url,'_blank');
  }
}

