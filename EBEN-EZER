      <td style="color:var(--muted)">${m.cantidad}</td>
      <td style="color:var(--muted)">${fmt(m.valorUnit)}</td>
      <td style="font-weight:700;color:var(--accent)">${fmt(m.valorUnit*m.cantidad)}</td>
      <td><span class="badge ${esCuenta?'badge-blue':'badge-orange'}">${esCuenta?'📋 Cuenta':'📦 Individual'}</span></td>
      <td><span class="badge ${m.pagado?'badge-green':'badge-red'}">${m.pagado?'✓ Pagado':'Pendiente'}</span></td></tr>`;
  }).join('');
  document.getElementById('hist-table').innerHTML=rows||`<tr><td colspan="8"><div class="empty-state">Sin movimientos para este filtro</div></td></tr>`;
}

