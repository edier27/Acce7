<style>
:root{
  --bg:#f7f6f3;
  --surface:#ffffff;
  --surface2:#f2f0ec;
  --surface3:#e8e5df;
  --border:#dedad3;
  --border2:#e8e5df;
  --ink:#1a1814;
  --ink2:#3d3a35;
  --ink3:#7a756e;
  --accent:#1c4f3c;
  --accent2:#2d7a5f;
  --accent-light:#e8f2ee;
  --accent-warm:#c8a96e;
  --accent-warm-light:#f5f0e8;
  --red:#b83a2e;
  --red-light:#fdf0ee;
  --green:#1c4f3c;
  --green-light:#e8f2ee;
  --blue:#2251a3;
  --blue-light:#eaf0fb;
  --shadow:0 1px 3px rgba(26,24,20,.06),0 4px 16px rgba(26,24,20,.06);
  --shadow-md:0 2px 8px rgba(26,24,20,.08),0 12px 40px rgba(26,24,20,.1);
  --shadow-lg:0 8px 24px rgba(26,24,20,.1),0 32px 80px rgba(26,24,20,.12);
  --font-head:'DM Sans',sans-serif;
  --font-body:'Inter',sans-serif;
  --r:10px;
  --r-lg:14px;
}
*{margin:0;padding:0;box-sizing:border-box;}
html{-webkit-font-smoothing:antialiased;}
body{background:var(--bg);color:var(--ink);font-family:var(--font-body);min-height:100vh;display:flex;flex-direction:column;}
.sidebar{display:none!important;}
.main{margin-left:0!important;padding:0;}
@keyframes fadeUp{from{opacity:0;transform:translateY(8px)}to{opacity:1;transform:translateY(0)}}

/* TOPBAR */
.topbar{background:var(--ink);display:flex;align-items:center;justify-content:space-between;padding:0 20px;height:52px;flex-shrink:0;}
.topbar-logo{display:flex;align-items:center;gap:10px;}
.topbar-icon{font-size:20px;}
.topbar-name{font-family:var(--font-head);font-size:16px;font-weight:800;color:#fff;letter-spacing:-.2px;}
.topbar-sub{font-size:10.5px;color:rgba(255,255,255,.4);font-weight:400;margin-top:1px;}
.topbar-actions{display:flex;gap:5px;align-items:center;}
.topbar-btn{background:rgba(255,255,255,.08);color:rgba(255,255,255,.75);border:1px solid rgba(255,255,255,.12);border-radius:7px;padding:5px 10px;font-size:11px;font-weight:600;cursor:pointer;font-family:var(--font-body);transition:all .15s;display:flex;align-items:center;gap:4px;}
.topbar-btn:hover{background:rgba(255,255,255,.16);color:#fff;}

/* STATUS BAR */
.undo-bar{background:var(--surface2);border-bottom:1px solid var(--border);display:flex;align-items:center;gap:6px;padding:4px 20px;flex-shrink:0;}
.undo-bar-label{font-size:10.5px;color:var(--ink3);font-weight:500;margin-right:4px;}

/* MAIN TABS */
.main-tabs{background:var(--surface);border-bottom:1px solid var(--border);display:flex;padding:0 20px;flex-shrink:0;}
.main-tab{padding:13px 18px;font-family:var(--font-head);font-size:12.5px;font-weight:700;cursor:pointer;color:var(--ink3);border:none;background:none;border-bottom:2px solid transparent;margin-bottom:-1px;transition:all .15s;letter-spacing:.3px;display:flex;align-items:center;gap:6px;}
.main-tab:hover{color:var(--ink2);}
.main-tab.active{color:var(--accent);border-bottom-color:var(--accent);}

/* TAB PANEL */
main.main{flex:1;padding:0;}
.tab-panel{display:none;padding:22px 20px 36px;animation:fadeUp .2s ease;}
.tab-panel.active{display:block;}

/* PAGE HEADER */
.page-header{display:flex;align-items:center;justify-content:space-between;margin-bottom:18px;flex-wrap:wrap;gap:10px;}
.page-title{font-family:var(--font-head);font-size:22px;font-weight:800;color:var(--ink);letter-spacing:-.5px;}
.page-title span{color:var(--accent);}
.header-actions{display:flex;gap:8px;align-items:center;flex-wrap:wrap;}

/* BUTTONS */
.btn{display:inline-flex;align-items:center;gap:6px;padding:9px 15px;border-radius:var(--r);font-size:12.5px;font-weight:600;cursor:pointer;border:none;font-family:var(--font-body);transition:all .14s;white-space:nowrap;letter-spacing:.1px;}
.btn-primary{background:var(--accent);color:#fff;}
.btn-primary:hover{background:#163d2f;transform:translateY(-1px);box-shadow:0 4px 12px rgba(28,79,60,.25);}
.btn-success{background:var(--accent);color:#fff;}
.btn-success:hover{background:#163d2f;transform:translateY(-1px);}
.btn-ghost{background:var(--surface);color:var(--ink2);border:1.5px solid var(--border);}
.btn-ghost:hover{border-color:var(--accent);color:var(--accent);background:var(--accent-light);}
.btn-amber{background:var(--ink2);color:#fff;}
.btn-amber:hover{background:var(--ink);transform:translateY(-1px);}
.btn-danger{background:var(--red);color:#fff;}
.btn-danger:hover{background:#9a2f25;transform:translateY(-1px);}
.btn-warning{background:var(--accent-warm);color:#fff;}
.btn-warning:hover{background:#b5944e;transform:translateY(-1px);}
.btn-sm{padding:6px 12px;font-size:12px;}
.btn-xs{padding:4px 9px;font-size:11px;border-radius:7px;}

/* CARD */
.card{background:var(--surface);border:1px solid var(--border);border-radius:var(--r-lg);padding:18px;box-shadow:var(--shadow);}

/* STATS */
.stats-grid{display:grid;grid-template-columns:repeat(4,1fr);gap:11px;margin-bottom:16px;}
.stat-card{background:var(--surface);border:1px solid var(--border);border-radius:var(--r-lg);padding:16px 18px;position:relative;overflow:hidden;box-shadow:var(--shadow);transition:transform .15s,box-shadow .15s;min-width:0;}
.stat-card:hover{transform:translateY(-2px);box-shadow:var(--shadow-md);}
.stat-card .bg-icon{position:absolute;right:12px;top:12px;font-size:28px;opacity:.07;}
.stat-label{font-size:9.5px;color:var(--ink3);text-transform:uppercase;letter-spacing:1px;font-weight:700;margin-bottom:8px;}
.stat-value{font-family:var(--font-head);font-size:22px;font-weight:800;letter-spacing:-.5px;color:var(--ink);overflow:hidden;text-overflow:ellipsis;white-space:nowrap;max-width:100%;display:block;}
.stat-sub{font-size:11px;color:var(--ink3);margin-top:4px;}
.s-blue .stat-value{color:var(--blue);}
.s-red .stat-value{color:var(--red);}
.s-green .stat-value{color:var(--accent);}
.s-gray .stat-value{color:var(--ink2);}
.s-blue{border-left:3px solid var(--blue);}
.s-red{border-left:3px solid var(--red);}
.s-green{border-left:3px solid var(--accent);}
.s-gray{border-left:3px solid var(--border);}

/* CHARTS */
.charts-grid{display:grid;grid-template-columns:1.4fr 1fr;gap:11px;margin-bottom:16px;}
.chart-title{font-family:var(--font-head);font-size:13.5px;font-weight:700;margin-bottom:13px;color:var(--ink);letter-spacing:-.2px;}

/* TABLE */
.table-wrap{overflow-x:auto;}
table{width:100%;border-collapse:collapse;font-size:12.5px;}
thead th{text-align:left;padding:9px 13px;font-size:9.5px;text-transform:uppercase;letter-spacing:.8px;color:var(--ink3);font-weight:700;border-bottom:1px solid var(--border);background:var(--surface2);}
tbody tr{border-bottom:1px solid var(--border2);transition:background .1s;}
tbody tr:hover{background:var(--surface2);}
tbody td{padding:10px 13px;color:var(--ink2);}

/* BADGES */
.badge{display:inline-block;padding:2px 8px;border-radius:5px;font-size:10px;font-weight:700;letter-spacing:.2px;}
.badge-red{background:var(--red-light);color:var(--red);}
.badge-green{background:var(--green-light);color:var(--green);}
.badge-amber{background:var(--accent-warm-light);color:#8a6b30;}
.badge-orange{background:var(--blue-light);color:var(--blue);}
.badge-blue{background:var(--blue-light);color:var(--blue);}
.badge-abono{background:#fef9e7;color:#8a6b30;}

/* AVATAR */
.avatar{width:32px;height:32px;border-radius:7px;display:inline-flex;align-items:center;justify-content:center;font-weight:800;font-size:11px;margin-right:8px;vertical-align:middle;font-family:var(--font-head);flex-shrink:0;}

/* MODAL */
.modal-overlay{display:none;position:fixed;inset:0;background:rgba(26,24,20,.55);z-index:300;align-items:center;justify-content:center;backdrop-filter:blur(4px);padding:16px;}
.modal-overlay.open{display:flex;}
.modal{background:var(--surface);border:1px solid var(--border);border-radius:var(--r-lg);padding:24px;width:520px;max-width:100%;max-height:92vh;overflow-y:auto;box-shadow:var(--shadow-lg);animation:fadeUp .18s ease;}
.modal-wide{width:640px;}
.modal-xl{width:780px;}
.modal-header{display:flex;align-items:center;justify-content:space-between;margin-bottom:20px;padding-bottom:16px;border-bottom:1px solid var(--border2);}
.modal-title{font-family:var(--font-head);font-size:16px;font-weight:800;color:var(--ink);letter-spacing:-.3px;}
.modal-close{background:var(--surface2);border:none;color:var(--ink3);width:28px;height:28px;border-radius:50%;display:flex;align-items:center;justify-content:center;cursor:pointer;font-size:14px;transition:.15s;}
.modal-close:hover{background:var(--border);color:var(--ink);}

/* FORM */
.form-group{margin-bottom:14px;}
.form-label{display:block;font-size:10px;font-weight:700;color:var(--ink3);text-transform:uppercase;letter-spacing:.8px;margin-bottom:6px;}
.form-input,.form-select{width:100%;background:var(--bg);border:1.5px solid var(--border);border-radius:var(--r);padding:10px 12px;color:var(--ink);font-family:var(--font-body);font-size:13.5px;outline:none;transition:all .14s;}
.form-input:focus,.form-select:focus{border-color:var(--accent);background:#fff;box-shadow:0 0 0 3px rgba(28,79,60,.1);}
.form-select option{background:#fff;}
.form-row{display:grid;grid-template-columns:1fr 1fr;gap:12px;}
.form-row-3{display:grid;grid-template-columns:1fr 1fr 1fr;gap:12px;}
.form-actions{display:flex;gap:8px;justify-content:flex-end;margin-top:20px;padding-top:16px;border-top:1px solid var(--border2);flex-wrap:wrap;}

/* PRODUCT LIST */
.product-list-modal{background:var(--surface2);border:1px solid var(--border);border-radius:var(--r);overflow:hidden;margin:10px 0;max-height:220px;overflow-y:auto;}
.pitem{display:flex;justify-content:space-between;align-items:center;padding:9px 12px;border-bottom:1px solid var(--border2);font-size:12.5px;gap:8px;}
.pitem:last-child{border-bottom:none;}
.pitem .info{flex:1;}
.pitem .name{font-weight:600;color:var(--ink);}
.pitem .meta{color:var(--ink3);font-size:10.5px;margin-top:2px;}
.pitem .price{font-weight:700;color:var(--accent);white-space:nowrap;font-family:var(--font-head);}
.pitem-remove{background:none;border:none;color:var(--ink3);cursor:pointer;font-size:12px;padding:3px 6px;border-radius:5px;transition:.13s;}
.pitem-remove:hover{color:var(--red);background:var(--red-light);}

/* TOTAL ROW */
.total-row{display:flex;justify-content:space-between;align-items:center;padding:12px 14px;background:var(--accent-light);border:1px solid rgba(28,79,60,.15);border-radius:var(--r);margin:10px 0;}
.total-row .label{font-weight:600;font-size:13px;color:var(--ink2);}
.total-row .amount{font-family:var(--font-head);font-size:21px;font-weight:800;color:var(--accent);}

/* SEARCH */
.search-wrap{position:relative;}
.search-wrap .sicon{position:absolute;left:10px;top:50%;transform:translateY(-50%);color:var(--ink3);font-size:12px;}
.search-input{background:var(--surface);border:1.5px solid var(--border);border-radius:var(--r);padding:8px 12px 8px 30px;color:var(--ink);font-family:var(--font-body);font-size:12.5px;outline:none;width:220px;transition:all .14s;}
.search-input:focus{border-color:var(--accent);box-shadow:0 0 0 3px rgba(28,79,60,.08);}

/* QUICK SEARCH */
.quick-search-bar{display:flex;gap:10px;align-items:center;background:var(--surface);border:1.5px solid var(--border);border-radius:var(--r-lg);padding:11px 15px;margin-bottom:16px;box-shadow:var(--shadow);transition:all .15s;}
.quick-search-bar:focus-within{border-color:var(--accent);box-shadow:0 0 0 3px rgba(28,79,60,.08);}
.quick-search-bar .qs-icon{font-size:17px;color:var(--ink3);}
.quick-search-bar input{flex:1;border:none;background:transparent;font-size:14px;color:var(--ink);font-family:var(--font-body);outline:none;}
.quick-search-bar input::placeholder{color:var(--ink3);}
.qs-results{position:absolute;left:0;right:0;top:calc(100%+6px);background:var(--surface);border:1px solid var(--border);border-radius:var(--r);box-shadow:var(--shadow-md);z-index:500;max-height:280px;overflow-y:auto;}
.qs-result-item{display:flex;align-items:center;gap:10px;padding:11px 13px;cursor:pointer;border-bottom:1px solid var(--border2);transition:background .1s;}
.qs-result-item:last-child{border-bottom:none;}
.qs-result-item:hover{background:var(--surface2);}
.qs-result-name{font-weight:700;color:var(--ink);font-size:13px;}
.qs-result-meta{font-size:11px;color:var(--ink3);margin-top:1px;}
.qs-result-debt{font-weight:800;font-family:var(--font-head);font-size:14px;color:var(--accent);}
.qs-wrap{position:relative;flex:1;}

/* DEBT BAR */
.debt-bar{height:3px;background:var(--border2);border-radius:3px;overflow:hidden;margin-top:5px;}
.debt-bar-fill{height:100%;border-radius:3px;}

/* CLIENT HEADER IN MODAL */
.cmh{display:flex;align-items:center;gap:12px;padding:12px 14px;background:var(--surface2);border-radius:var(--r);margin-bottom:16px;border:1px solid var(--border);}
.avatar-lg{width:44px;height:44px;border-radius:9px;display:flex;align-items:center;justify-content:center;font-size:16px;font-weight:800;font-family:var(--font-head);flex-shrink:0;}
.cmh-name{font-family:var(--font-head);font-size:15px;font-weight:800;color:var(--ink);}
.cmh-meta{color:var(--ink3);font-size:11.5px;margin-top:2px;}

/* MPS */
.mps-list{background:var(--bg);border:1px solid var(--border);border-radius:var(--r);overflow:hidden;margin:8px 0;}
.mps-item{display:flex;align-items:center;justify-content:space-between;padding:9px 12px;border-bottom:1px solid var(--border2);font-size:12.5px;gap:8px;}
.mps-item:last-child{border-bottom:none;}
.mps-item-name{font-weight:600;color:var(--ink);flex:1;}
.mps-item-qty{color:var(--ink3);font-size:11px;}
.mps-item-price{font-weight:700;color:var(--accent);white-space:nowrap;font-family:var(--font-head);}
.mps-empty{text-align:center;padding:14px;color:var(--ink3);font-size:12.5px;}
.add-line-form{background:var(--surface2);border:1.5px dashed var(--border);border-radius:var(--r);padding:13px;margin:10px 0;}
.add-line-title{font-size:10px;font-weight:700;color:var(--ink3);text-transform:uppercase;letter-spacing:.8px;margin-bottom:10px;}
.add-line-row{display:grid;grid-template-columns:2fr 1fr 1.2fr auto;gap:8px;align-items:end;}

/* LIQ */
.liq-stats{display:grid;grid-template-columns:repeat(3,1fr);gap:11px;margin-bottom:16px;}
.liq-filter-bar{display:flex;gap:10px;align-items:center;margin-bottom:13px;flex-wrap:wrap;}
.liq-detalle-list{background:var(--surface2);border:1px solid var(--border);border-radius:var(--r);padding:8px;margin-top:8px;max-height:180px;overflow-y:auto;}
.liq-detalle-item{display:flex;justify-content:space-between;align-items:center;padding:6px 8px;border-bottom:1px solid var(--border2);font-size:12px;}
.liq-detalle-item:last-child{border-bottom:none;}

/* APF */
.apf{background:var(--bg);border:1.5px dashed var(--border);border-radius:var(--r);padding:12px;margin:10px 0;}
.apf-title{font-size:10px;font-weight:700;color:var(--ink3);text-transform:uppercase;letter-spacing:.6px;margin-bottom:10px;}

/* TOAST */
.toast{position:fixed;bottom:20px;right:20px;padding:11px 16px;border-radius:var(--r);font-weight:600;font-size:12.5px;z-index:9999;font-family:var(--font-body);box-shadow:var(--shadow-md);animation:fadeUp .18s ease;display:flex;align-items:center;gap:8px;}
.toast-success{background:var(--ink);color:#fff;}
.toast-info{background:var(--blue);color:#fff;}

.slabel{font-size:9.5px;font-weight:700;color:var(--ink3);text-transform:uppercase;letter-spacing:.9px;margin-bottom:8px;}
.empty-state{text-align:center;padding:36px 20px;color:var(--ink3);font-size:13px;}
.divider{height:1px;background:var(--border2);margin:14px 0;}
.section-title{font-family:var(--font-head);font-size:14px;font-weight:700;color:var(--ink);margin-bottom:12px;letter-spacing:-.2px;}

/* PRINT */
#print-area{display:none;}
@media print{body>*:not(#print-area){display:none!important;}#print-area{display:block!important;padding:20px;}}

/* EDIT LIQ */
.edit-liq-row{display:flex;gap:6px;align-items:center;margin-bottom:6px;}

/* NEQUI QR */
.nequi-qr-box{background:var(--accent-light);border:1px solid rgba(28,79,60,.18);border-radius:var(--r);padding:14px;text-align:center;margin-top:10px;}

/* SUB-NAV */
.sub-nav{display:flex;gap:4px;flex-wrap:wrap;margin-bottom:18px;background:var(--surface);border:1px solid var(--border);border-radius:var(--r);padding:5px;}
.sub-nav-item{padding:6px 11px;border-radius:7px;font-size:11.5px;font-weight:600;cursor:pointer;color:var(--ink3);transition:all .14s;}
.sub-nav-item:hover{color:var(--ink2);background:var(--surface2);}
.sub-nav-item.active{color:var(--accent);background:var(--accent-light);font-weight:700;}
.sub-page{display:none;}
.sub-page.active{display:block;animation:fadeUp .18s ease;}

/* NOTEBOOK */
.notebook-wrap{max-width:720px;margin:0 auto;width:100%;}
.notebook{background:#fff;border-radius:var(--r-lg);box-shadow:var(--shadow-md);position:relative;overflow:visible;margin-bottom:22px;border:1px solid var(--border);}
.notebook::before{content:'';position:absolute;left:50px;top:0;bottom:0;width:1px;background:rgba(200,169,110,.25);z-index:0;}
.notebook-lines{position:absolute;inset:0;z-index:0;pointer-events:none;
  background-image:repeating-linear-gradient(transparent,transparent 31px,rgba(200,169,110,.12) 31px,rgba(200,169,110,.12) 32px);
  background-position:0 52px;}
.notebook-header{background:var(--ink);padding:16px 14px 16px 62px;position:relative;z-index:1;border-radius:var(--r-lg) var(--r-lg) 0 0;}
.notebook-header-title{font-family:var(--font-head);font-size:18px;font-weight:800;color:#fff;letter-spacing:-.2px;}
.notebook-header-sub{font-size:11px;color:rgba(255,255,255,.45);margin-top:3px;}
.notebook-body{padding:16px 14px 20px 62px;position:relative;z-index:1;overflow:visible;}
.notebook-section{font-family:var(--font-head);font-size:13.5px;font-weight:700;color:var(--ink);margin:16px 0 11px;padding-bottom:6px;border-bottom:1px solid var(--border2);display:flex;align-items:center;gap:8px;letter-spacing:-.2px;}
.notebook-section:first-child{margin-top:0;}
.notebook-holes{position:absolute;left:0;top:0;bottom:0;width:50px;background:var(--surface2);display:flex;flex-direction:column;align-items:center;justify-content:space-around;padding:24px 0;z-index:1;border-right:1px solid var(--border);border-radius:var(--r-lg) 0 0 var(--r-lg);}
.notebook-hole{width:15px;height:15px;border-radius:50%;background:#fff;border:1px solid var(--border);}

/* CLI SEARCH */
.cli-search-box{background:var(--surface2);border:1.5px solid var(--border);border-radius:var(--r);padding:11px 13px;margin-bottom:13px;position:relative;overflow:visible;transition:all .15s;}
.cli-search-box:focus-within{border-color:var(--accent);box-shadow:0 0 0 3px rgba(28,79,60,.08);}
.cli-search-box input{width:100%;border:none;background:transparent;font-size:14px;color:var(--ink);font-family:var(--font-body);outline:none;}
.cli-search-box .search-icon{font-size:15px;margin-right:7px;vertical-align:middle;opacity:.45;}
.cli-found-card{background:var(--accent-light);border:1px solid rgba(28,79,60,.18);border-radius:var(--r);padding:11px 13px;display:flex;align-items:center;gap:11px;margin-bottom:13px;}
.cli-found-card .cfc-name{font-family:var(--font-head);font-size:14px;font-weight:800;color:var(--ink);}
.cli-found-card .cfc-meta{font-size:11px;color:var(--ink3);margin-top:2px;}
.cli-found-card .cfc-deuda{font-family:var(--font-head);font-size:17px;font-weight:800;color:var(--accent);margin-left:auto;}
.cli-results-drop{position:absolute;left:0;right:0;top:calc(100%+4px);background:var(--surface);border:1px solid var(--border);border-radius:var(--r);box-shadow:var(--shadow-md);z-index:500;max-height:260px;overflow-y:auto;}

/* REG MODE */
.reg-mode-tabs{display:grid;grid-template-columns:repeat(4,1fr);gap:5px;margin-bottom:16px;}
.reg-mode-tab{padding:9px 6px;border-radius:var(--r);font-size:11.5px;font-weight:700;cursor:pointer;border:1.5px solid var(--border);background:var(--surface);color:var(--ink3);transition:all .14s;text-align:center;line-height:1.3;}
.reg-mode-tab:hover:not(.active){background:var(--surface2);color:var(--ink2);}
.reg-mode-tab.active{background:var(--ink);color:#fff;border-color:var(--ink);}
.reg-mode-panel{display:none;}
.reg-mode-panel.active{display:block;}

/* FECHA */
.fecha-grande{font-size:12px;font-weight:500;color:var(--ink3);text-align:right;margin-bottom:11px;letter-spacing:.2px;}

/* RESPONSIVE */
@media(max-width:520px){
  .topbar{padding:0 12px;}
  .topbar-name{font-size:14px;}
  .topbar-sub{display:none;}
  .topbar-btn{font-size:10px;padding:5px 8px;}
  .topbar-btn:nth-child(n+3){display:none!important;}
  .undo-bar-label{display:none;}
  .main-tab{padding:11px 12px;font-size:12px;}
  .tab-panel{padding:14px 12px 28px;}
  .notebook-holes{width:36px;}
  .notebook-header{padding:13px 10px 13px 44px;}
  .notebook-body{padding:13px 10px 16px 44px;}
  .notebook::before{left:36px;}
  .add-line-row{grid-template-columns:1fr 1fr;gap:6px;}
  .add-line-row>div:first-child{grid-column:1/-1;}
  .form-row{grid-template-columns:1fr;}
  .form-row-3{grid-template-columns:1fr 1fr;}
  .stats-grid{grid-template-columns:1fr 1fr;}
  .charts-grid{grid-template-columns:1fr;}
  .sub-nav{padding:4px;gap:3px;}
  .sub-nav-item{padding:5px 8px;font-size:11px;}
  .page-header{flex-direction:column;align-items:flex-start;}
  .reg-mode-tabs{grid-template-columns:1fr 1fr;gap:4px;}
  .reg-mode-tab{font-size:11px;padding:8px 4px;}
  .stat-card{padding:13px 14px;}
  .stat-value{font-size:20px;}
  .modal{border-radius:12px;padding:16px;}
  main.main{padding:0;}
}
@media(max-width:360px){.topbar-btn{display:none!important;}#btn-instalar{display:none!important;}}
input[type="month"].form-input{cursor:pointer;}
</style>
</head>
<body>

<div id="print-area"></div>

<!-- TOPBAR -->
<div class="topbar">
  <div class="topbar-logo">
    <div class="topbar-icon">🏪</div>
    <div>
      <div class="topbar-name">Tienda Eben-ezer</div>
      <div class="topbar-sub" id="topbar-deuda-total">Sistema de Fiados</div>
    </div>
  </div>
  <div class="topbar-actions">
    <button id="btn-instalar" onclick="instalarPWA()" class="topbar-btn" style="display:none;">📲 Instalar App</button>
    <button class="topbar-btn" onclick="openModal('m-nequi-config')" title="Configurar Nequi/QR">📱 Nequi/QR</button>
    <button class="topbar-btn" onclick="exportarHTML()">📲 Compartir App</button>
    <button class="topbar-btn" onclick="exportarDatos()">💾 Respaldo</button>
    <button class="topbar-btn" onclick="exportarExcel()">📊 Excel</button>
  </div>
</div>

<!-- STATUS BAR -->
<div class="undo-bar">
  <span class="undo-bar-label" id="save-status">💾 Datos guardados</span>
  <div style="flex:1"></div>
  <button class="btn btn-ghost btn-xs" onclick="diagnosticarStorage()" title="Ver estado del almacenamiento">🔍 Estado</button>
  <button class="btn btn-ghost btn-xs" onclick="document.getElementById('imp').click()">📂 Importar</button>
  <input type="file" id="imp" accept=".json,.xlsx,.xls" style="display:none" onchange="importarDatos(event)">
</div>

<!-- MAIN TABS -->
<div class="main-tabs">
  <button class="main-tab active" id="mtab-registro" onclick="switchMainTab('registro')">📝 Registro</button>
  <button class="main-tab" id="mtab-reportes" onclick="switchMainTab('reportes')">📊 Reportes</button>
</div>

<main class="main">

<!-- ══════════════════════════════════ -->
<!-- TAB: REGISTRO (CUADERNO) -->
<!-- ══════════════════════════════════ -->
<div id="tab-registro" class="tab-panel active">
  <div class="notebook-wrap">

    <!-- Fecha -->
    <div class="fecha-grande" id="fecha-hoy-display"></div>

    <!-- MODOS: Nuevo Cliente / Agregar a Cliente / Liquidar -->
    <div class="reg-mode-tabs">
      <div class="reg-mode-tab active" id="rmt-nuevo" onclick="switchRegMode('nuevo')">👤 Nuevo Cliente</div>
      <div class="reg-mode-tab" id="rmt-agregar" onclick="switchRegMode('agregar')">➕ Agregar Productos</div>
      <div class="reg-mode-tab" id="rmt-liquidar" onclick="switchRegMode('liquidar')">✅ Pagar</div>
      <div class="reg-mode-tab" id="rmt-buscar" onclick="switchRegMode('buscar')">🔍 Buscar Cliente</div>
    </div>

    <!-- ── MODO: NUEVO CLIENTE ── -->
    <div class="reg-mode-panel active" id="rmp-nuevo">
      <div class="notebook">
        <div class="notebook-holes"><div class="notebook-hole"></div><div class="notebook-hole"></div><div class="notebook-hole"></div><div class="notebook-hole"></div></div>
        <div class="notebook-lines"></div>
        <div class="notebook-header">
          <div class="notebook-header-title">📋 Nuevo Cliente</div>
          <div class="notebook-header-sub">Registra los datos del cliente y sus productos</div>
        </div>
        <div class="notebook-body">
          <div class="notebook-section">👤 Datos del Cliente</div>
          <div class="form-group"><label class="form-label">Nombre Completo *</label><input class="form-input" id="reg-nc-n" placeholder="Ej: María García"></div>
          <div class="form-group"><label class="form-label">Teléfono</label><input class="form-input" id="reg-nc-t" placeholder="300 000 0000"></div>

          <div class="notebook-section">📦 Productos</div>
          <div class="add-line-form" style="margin-left:0;margin-right:0;">
            <div class="add-line-title">➕ Agregar producto</div>
            <div class="add-line-row">
              <div class="form-group" style="margin:0;"><label class="form-label">Producto</label><input class="form-input" id="reg-nc-pnombre" placeholder="Nombre del producto" onkeydown="if(event.key==='Enter')document.getElementById('reg-nc-pq').focus()"></div>
              <div class="form-group" style="margin:0;"><label class="form-label">Cantidad</label><input class="form-input" id="reg-nc-pq" type="number" min="1" value="1"></div>
              <div class="form-group" style="margin:0;"><label class="form-label">Valor $</label><input class="form-input" id="reg-nc-pv" type="number" min="0" placeholder="0" onkeydown="if(event.key==='Enter')regNcAgregarProd()"></div>
              <div><button class="btn btn-primary" onclick="regNcGuardarDirecto()" style="height:42px;margin-top:17px;white-space:nowrap;">💾 Guardar</button></div>
            </div>
          </div>
          <div id="reg-nc-prod-list" style="display:none;">
            <div class="slabel" style="margin-bottom:6px;">Productos a registrar</div>
            <div class="mps-list" id="reg-nc-mps-list"></div>
            <div class="total-row" id="reg-nc-total-row"><span class="label">Total inicial:</span><span class="amount" id="reg-nc-total-v">$0</span></div>
          </div>
          <div class="form-group" style="margin-top:12px;"><label class="form-label">Fecha</label><input class="form-input" id="reg-nc-fecha" type="date" style="max-width:200px;"></div>
          <div class="form-actions" style="padding-top:14px;border-top:1px solid var(--border2);">
            <button class="btn btn-ghost" onclick="regNcLimpiar()">🗑️ Limpiar</button>
            <button class="btn btn-primary" onclick="regCrearCliente()">✓ Crear Cliente</button>
          </div>
        </div>
      </div>
    </div>

    <!-- ── MODO: AGREGAR PRODUCTOS A CLIENTE EXISTENTE ── -->
    <div class="reg-mode-panel" id="rmp-agregar">
      <div class="notebook">
        <div class="notebook-holes"><div class="notebook-hole"></div><div class="notebook-hole"></div><div class="notebook-hole"></div><div class="notebook-hole"></div></div>
        <div class="notebook-lines"></div>
        <div class="notebook-header">
          <div class="notebook-header-title">➕ Agregar</div>
          <div class="notebook-header-sub">Busca el cliente y agrega lo que llevó hoy</div>
        </div>
        <div class="notebook-body">
          <div class="notebook-section">🔍 Seleccionar Cliente</div>
          <div class="cli-search-box" style="position:relative;">
            <span class="search-icon">🔍</span>
            <input id="reg-buscar-cliente" placeholder="Escribe el nombre o teléfono del cliente..." oninput="regBuscarCliente(this.value)" onkeydown="regBuscarKey(event,'agregar')" autocomplete="off">
            <div class="cli-results-drop" id="reg-cli-results-agregar" style="display:none;"></div>
          </div>
          <div id="reg-cli-found-agregar" style="display:none;" class="cli-found-card">
            <div class="avatar" id="reg-cli-av-agregar" style="font-size:13px;width:42px;height:42px;"></div>
            <div><div class="cfc-name" id="reg-cli-name-agregar"></div><div class="cfc-meta" id="reg-cli-meta-agregar"></div></div>
            <div class="cfc-deuda" id="reg-cli-deuda-agregar"></div>
            <button class="btn btn-xs btn-ghost" onclick="regLimpiarClienteAgregar()">✕ Cambiar</button>
          </div>

          <div id="reg-agregar-form" style="display:none;">
            <div class="notebook-section">📦 Productos a Agregar</div>

            <!-- FILA DE ENTRADA -->
            <div class="add-line-form" style="margin:0 0 10px;">
              <div class="add-line-title">Ingresa cada producto y presiona <strong>➕ Añadir</strong> para acumularlo en la lista. Al terminar, presiona <strong>💾 Guardar Todos</strong>.</div>
              <div class="add-line-row" style="grid-template-columns:2fr 1fr 1.2fr auto auto;">
                <div class="form-group" style="margin:0;"><label class="form-label">Producto</label>
                  <input class="form-input" id="reg-ag-np" placeholder="Nombre del producto"
                    onkeydown="if(event.key==='Enter')document.getElementById('reg-ag-nq').focus()">
                </div>
                <div class="form-group" style="margin:0;"><label class="form-label">Cantidad</label>
                  <input class="form-input" id="reg-ag-nq" type="number" min="1" value="1"
                    oninput="regAgPrev()"
                    onkeydown="if(event.key==='Enter')document.getElementById('reg-ag-nv').focus()">
                </div>
                <div class="form-group" style="margin:0;"><label class="form-label">Valor $</label>
                  <input class="form-input" id="reg-ag-nv" type="number" min="0" placeholder="0"
                    oninput="regAgPrev()"
                    onkeydown="if(event.key==='Enter')regAgAnadirALista()">
                </div>
                <div style="margin-top:17px;">
                  <button class="btn btn-primary" onclick="regAgAnadirALista()" style="height:42px;white-space:nowrap;" title="Añadir a la lista sin guardar aún">
                    ➕ Añadir
                  </button>
                </div>
                <div style="margin-top:17px;">
                  <button class="btn btn-ghost" onclick="regAgGuardarDirecto()" style="height:42px;white-space:nowrap;" title="Guardar este solo producto directamente">
                    💾 Directo
                  </button>
                </div>
              </div>
              <div id="reg-ag-prev" style="display:none;font-size:12.5px;color:var(--accent);font-weight:700;margin-top:6px;text-align:right;"></div>
            </div>

            <!-- LISTA ACUMULADA -->
            <div id="reg-ag-list-wrap" style="display:none;">
              <div style="display:flex;align-items:center;justify-content:space-between;margin-bottom:6px;">
                <div class="slabel" id="reg-ag-list-label" style="margin:0;">Lista de productos a guardar</div>
                <button class="btn btn-xs btn-ghost" onclick="regAgLimpiarLista()" style="color:var(--red);border-color:var(--red);">🗑️ Limpiar lista</button>
              </div>
              <div class="mps-list" id="reg-ag-list"></div>
              <div class="total-row" id="reg-ag-total-row">
                <span class="label">Total a registrar:</span>
                <span class="amount" id="reg-ag-total-v">$0</span>
              </div>
            </div>

            <div class="form-group" style="margin-top:12px;"><label class="form-label">Fecha</label><input class="form-input" id="reg-ag-fecha" type="date" style="max-width:200px;"></div>

            <div class="form-actions">
              <button class="btn btn-ghost" onclick="verDetalle(regAgClienteId)">👁️ Ver Cuenta</button>
              <button class="btn btn-ghost" onclick="enviarWhatsApp(regAgClienteId,'deuda')" id="reg-ag-wa-btn">💬 WhatsApp</button>
              <button class="btn btn-success" onclick="liquidar(regAgClienteId)" id="reg-ag-liq-btn">✓ Pagar</button>
              <button class="btn btn-primary" id="reg-ag-save-btn" onclick="regAgGuardar()">💾 Guardar Todos</button>
            </div>
          </div>
        </div>
      </div>
    </div>

    <!-- ── MODO: LIQUIDAR CUENTA ── -->
    <div class="reg-mode-panel" id="rmp-liquidar">
      <div class="notebook">
        <div class="notebook-holes"><div class="notebook-hole"></div><div class="notebook-hole"></div><div class="notebook-hole"></div><div class="notebook-hole"></div></div>
        <div class="notebook-lines"></div>
        <div class="notebook-header">
          <div class="notebook-header-title">✅ Liquidar</div>
          <div class="notebook-header-sub">Cobra y cierra la deuda de un cliente</div>
        </div>
        <div class="notebook-body">
          <div class="notebook-section">🔍 Seleccionar Cliente</div>
          <div class="cli-search-box" style="position:relative;">
            <span class="search-icon">🔍</span>
            <input id="reg-buscar-liq" placeholder="Escribe el nombre o teléfono del cliente..." oninput="regBuscarClienteLiq(this.value)" onkeydown="regBuscarKey(event,'liquidar')" autocomplete="off">
            <div class="cli-results-drop" id="reg-cli-results-liq" style="display:none;"></div>
          </div>
          <div id="reg-liq-detalle" style="display:none;"></div>
        </div>
      </div>
    </div>

    <!-- ── MODO: BUSCAR CLIENTE ── -->
    <div class="reg-mode-panel" id="rmp-buscar">
      <div class="notebook">
        <div class="notebook-holes"><div class="notebook-hole"></div><div class="notebook-hole"></div><div class="notebook-hole"></div><div class="notebook-hole"></div></div>
        <div class="notebook-lines"></div>
        <div class="notebook-header">
          <div class="notebook-header-title">🔍 Buscar</div>
          <div class="notebook-header-sub">Consulta la deuda y cuenta de cualquier cliente</div>
        </div>
        <div class="notebook-body">
          <div class="cli-search-box" style="position:relative;">
            <span class="search-icon">🔍</span>
            <input id="reg-buscar-general" placeholder="Nombre o teléfono..." oninput="regBuscarGeneral(this.value)" autocomplete="off">
            <div class="cli-results-drop" id="reg-cli-results-general" style="display:none;"></div>
          </div>
          <div id="reg-general-result" style="margin-top:12px;"></div>
        </div>
      </div>
    </div>

  </div><!-- /notebook-wrap -->
</div><!-- /tab-registro -->

<!-- ══════════════════════════════════ -->
<!-- TAB: REPORTES -->
<!-- ══════════════════════════════════ -->
<div id="tab-reportes" class="tab-panel">
  <!-- Sub-nav de reportes -->
  <div class="sub-nav">
    <div class="sub-nav-item active" id="snav-dashboard" onclick="switchSubPage('dashboard')">📊 Dashboard</div>
    <div class="sub-nav-item" id="snav-clientes" onclick="switchSubPage('clientes')">👥 Clientes</div>
    <div class="sub-nav-item" id="snav-historial" onclick="switchSubPage('historial')">📋 Historial</div>
    <div class="sub-nav-item" id="snav-liquidaciones" onclick="switchSubPage('liquidaciones')">✅ Liquidaciones</div>
    <div class="sub-nav-item" id="snav-productos-dia" onclick="switchSubPage('productos-dia')">📆 Por Día</div>
  </div>

  <!-- DASHBOARD -->
  <div class="sub-page active" id="sub-dashboard">
    <div class="page-header">
      <div class="page-title">Panel de <span>Control</span></div>
      <div class="header-actions">
        <button class="btn btn-ghost btn-sm" onclick="exportarExcel()">📊 Excel</button>
        <button class="btn btn-ghost btn-sm" onclick="exportarDatos()">💾 Respaldo</button>
      </div>
    </div>
    <div style="position:relative;">
      <div class="quick-search-bar">
        <span class="qs-icon">🔍</span>
        <div class="qs-wrap">
          <input id="qs-input" placeholder="Buscar cliente... (nombre o teléfono)" oninput="busquedaRapida(this.value)" onkeydown="qsKey(event)">
          <div class="qs-results" id="qs-results" style="display:none;"></div>
        </div>
        <button class="btn btn-primary btn-sm" onclick="qsVerDetalle()" id="qs-btn-ver" style="display:none">👁️ Ver Deuda</button>
      </div>
    </div>
    <div class="stats-grid" id="stats-grid"></div>
    <div class="charts-grid">
      <div class="card"><div class="chart-title">📦 Deuda por Cliente</div><canvas id="chart-bar" height="180"></canvas></div>
      <div class="card"><div class="chart-title">🥧 Distribución Total</div><canvas id="chart-doughnut" height="180"></canvas></div>
    </div>
    <div class="card">
      <div style="display:flex;align-items:center;justify-content:space-between;margin-bottom:13px">
        <div class="chart-title" style="margin:0">🏆 Ranking de Deudores</div>
        <button class="btn btn-ghost btn-sm" onclick="switchSubPage('clientes')">Ver todos →</button>
      </div>
      <div class="table-wrap"><table>
        <thead><tr><th>Cliente</th><th>Teléfono</th><th>Deuda</th><th>Último Mov.</th><th>Estado</th><th>Acciones</th></tr></thead>
        <tbody id="top-table"></tbody>
      </table></div>
    </div>
  </div>

  <!-- CLIENTES -->
  <div class="sub-page" id="sub-clientes">
    <div class="page-header">
      <div class="page-title">Mis <span>Clientes</span></div>
      <div class="header-actions">
        <div class="search-wrap"><span class="sicon">🔍</span><input class="search-input" placeholder="Buscar..." oninput="filtrar(this.value)"></div>
        <select class="form-select" id="cli-estado-filter" style="width:160px;" onchange="filtrar(document.querySelector('.search-input').value)">
          <option value="todos">Todos</option>
          <option value="deudores">Solo deudores</option>
          <option value="al-dia">Al día</option>
        </select>
        <button class="btn btn-primary" onclick="openNuevoCliente()">＋ Nuevo Cliente</button>
      </div>
    </div>
    <div class="card">
      <div class="table-wrap"><table>
        <thead><tr><th>Cliente</th><th>Teléfono</th><th>Deuda</th><th>Ítems</th><th>Estado</th><th>Acciones</th></tr></thead>
        <tbody id="cli-table"></tbody>
      </table></div>
    </div>
  </div>

  <!-- HISTORIAL -->
  <div class="sub-page" id="sub-historial">
    <div class="page-header">
      <div class="page-title">Historial de <span>Movimientos</span></div>
    </div>
    <div class="card">
      <div style="display:flex;gap:10px;align-items:center;margin-bottom:14px;flex-wrap:wrap;">
        <div class="search-wrap" style="flex:1;min-width:180px;"><span class="sicon">🔍</span><input class="search-input" style="width:100%;" id="hist-search" placeholder="Buscar por cliente o producto..." oninput="renderHist()"></div>
        <select class="form-select" id="hist-filter" style="width:160px;" onchange="renderHist()">
          <option value="todos">Todos los estados</option>
          <option value="pendiente">Pendientes</option>
          <option value="pagado">Pagados</option>
        </select>
        <select class="form-select" id="hist-cliente-filter" style="width:180px;" onchange="renderHist()">
          <option value="">Todos los clientes</option>
        </select>
      </div>
      <div id="hist-resumen" style="display:none;background:var(--accent-light);border:1px solid rgba(37,99,168,.2);border-radius:8px;padding:11px 15px;margin-bottom:12px;font-size:13px;color:var(--text2);"></div>
      <div class="table-wrap"><table>
        <thead><tr><th>Fecha</th><th>Cliente</th><th>Producto / Cuenta</th><th>Cant.</th><th>Val. Unit.</th><th>Total</th><th>Tipo</th><th>Estado</th></tr></thead>
        <tbody id="hist-table"></tbody>
      </table></div>
    </div>
  </div>

  <!-- LIQUIDACIONES -->
  <div class="sub-page" id="sub-liquidaciones">
    <div class="page-header">
      <div class="page-title">Historial de <span>Liquidaciones</span></div>
      <button class="btn btn-ghost btn-sm" onclick="exportarLiquidacionesExcel()">📊 Exportar Liquidaciones</button>
    </div>
    <div class="liq-stats">
