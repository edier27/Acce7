function importarDatos(e){
  let f=e.target.files[0];if(!f)return;
  let ext=f.name.split('.').pop().toLowerCase();
  if(ext==='json'){
    let r=new FileReader();
    r.onload=function(ev){
      try{
        let imp=JSON.parse(ev.target.result);
        if(!imp.clientes||!imp.movimientos)throw new Error();
        if(!confirm(`¿Importar datos?\nEsto reemplazará la información actual.\n\nClientes: ${imp.clientes.length}\nMovimientos: ${imp.movimientos.length}`))return;
        db=imp;
        if(!db.nci)db.nci=Math.max(0,...db.clientes.map(c=>c.id))+1;
        if(!db.nmi)db.nmi=Math.max(0,...db.movimientos.map(m=>m.id))+1;
        if(!db.liquidaciones)db.liquidaciones=[];
        if(!db.nli)db.nli=1;
        db.liquidaciones.forEach(l=>{if(!l.detalle)l.detalle=[];});
        save("Importar JSON");refreshAll();
        toast(`✓ Importado: ${db.clientes.length} clientes, ${db.movimientos.length} movimientos`);
      }catch{toast('❌ Archivo inválido. Usa un respaldo JSON exportado desde esta app.','info');}
    };
    r.readAsText(f);
  } else if(ext==='xlsx'||ext==='xls'){
    let r=new FileReader();
    r.onload=function(ev){
      try{
        let wb=XLSX.read(ev.target.result,{type:'binary'});
        // Intentar leer hoja Clientes
        let cliSheet=wb.Sheets['Clientes'];
        let movSheet=wb.Sheets['Movimientos'];
        if(!cliSheet||!movSheet){toast('❌ El Excel debe tener hojas "Clientes" y "Movimientos"','info');return;}
        if(!confirm('¿Importar datos desde Excel?\nEsto reemplazará la información actual.'))return;
        let cliRows=XLSX.utils.sheet_to_json(cliSheet,{header:1}).slice(1);
        let movRows=XLSX.utils.sheet_to_json(movSheet,{header:1}).slice(1);
        const CC=['#2563a8','#1a7a4a','#6b4c9a','#4a7fb5','#2980b9','#c0392b','#16a085'];
        db.clientes=cliRows.filter(r=>r[1]).map((r,i)=>({id:parseInt(r[0])||i+1,nombre:String(r[1]),telefono:String(r[2]||'—'),direccion:String(r[3]||'—'),color:CC[i%CC.length]}));
        db.movimientos=movRows.filter(r=>r[3]).map(r=>({id:parseInt(r[0])||db.nmi++,fecha:String(r[1]||today()),clienteId:parseInt(r[0])||1,producto:String(r[3]),cantidad:parseInt(r[4])||1,valorUnit:parseFloat(r[5])||0,pagado:String(r[7])==='Pagado',tipo:'individual'}));
        // Reconstruir clienteId en movimientos por nombre
        db.movimientos.forEach((m,i)=>{
          let cliNombre=String(movRows[i]?.[2]||'');
          let c=db.clientes.find(x=>x.nombre===cliNombre);
          if(c)m.clienteId=c.id;
        });
        db.nci=Math.max(0,...db.clientes.map(c=>c.id))+1;
        db.nmi=Math.max(0,...db.movimientos.map(m=>m.id))+1;
        if(!db.liquidaciones)db.liquidaciones=[];
        if(!db.nli)db.nli=1;
        save("Importar Excel");refreshAll();
        toast(`✓ Excel importado: ${db.clientes.length} clientes, ${db.movimientos.length} movimientos`);
      }catch(err){toast('❌ Error al leer el Excel. Verifica el formato.','info');}
    };
    r.readAsBinaryString(f);
  } else {
    toast('❌ Formato no soportado. Usa .json o .xlsx','info');
  }
  e.target.value='';
}

