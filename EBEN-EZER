function renderCli(f='',estado='todos'){
  let lista=db.clientes.filter(c=>{
    let matchText=!f||c.nombre.toLowerCase().includes(f.toLowerCase())||c.telefono.includes(f);
    let d=deuda(c.id);
    let matchEstado=estado==='todos'||(estado==='deudores'&&d>0)||(estado==='al-dia'&&d===0);
    return matchText&&matchEstado;
  });
  let maxD=Math.max(...db.clientes.map(c=>deuda(c.id)),1);
  let rows=lista.map(c=>{
    let d=deuda(c.id),pct=Math.round(d/maxD*100),mv=activos(c.id).length;
    return`<tr>
      <td><span class="avatar" style="background:${c.color}22;color:${c.color}">${ini(c.nombre)}</span><strong>${c.nombre}</strong></td>
      <td>${c.telefono}</td>
      <td><div style="font-weight:700;color:${d>0?'var(--accent)':'var(--green)'}">${fmt(d)}</div><div class="debt-bar"><div class="debt-bar-fill" style="width:${pct}%;background:${c.color}"></div></div></td>
      <td><span class="badge badge-amber">${mv} ítem${mv!==1?'s':''}</span></td>
      <td><span class="badge ${d>0?'badge-red':'badge-green'}">${d>0?'Debe':'Al día'}</span></td>
      <td style="display:flex;gap:4px;flex-wrap:wrap">
        <button class="btn btn-xs btn-amber" onclick="verDetalle(${c.id})">👁️ Ver Deuda</button>
        ${d>0?`<button class="btn btn-xs btn-success" onclick="liquidar(${c.id})">✓ Liquidar</button>`:''}
        <button class="btn btn-xs btn-ghost" onclick="editarCliente(${c.id})" title="Editar cliente">✏️ Editar</button>
        <button class="btn btn-xs btn-danger" onclick="eliminarCliente(${c.id})" title="Eliminar cliente">🗑️</button>
      </td></tr>`;}).join('');
  document.getElementById('cli-table').innerHTML=rows||`<tr><td colspan="7"><div class="empty-state">No encontrado</div></td></tr>`;
}
function filtrar(v){
  let estado=document.getElementById('cli-estado-filter')?.value||'todos';
  renderCli(v||document.querySelector('#sub-clientes .search-input')?.value||'', estado);
}

