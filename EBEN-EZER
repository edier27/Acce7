function render(p){
  // Actualizar siempre la barra superior (deuda total)
  _updateTopbarDeuda();
  // Si no hay página de reporte activa (estamos en Registro), no renderizar tabla
  if(p==='__registro__') return;
  if(p==='dashboard')renderDash();
  else if(p==='clientes')renderCli();
  else if(p==='historial')renderHist();
  else if(p==='liquidaciones')renderLiq();
  else if(p==='productos-dia')renderProdDia();
}

