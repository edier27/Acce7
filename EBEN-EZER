function detPrev(){
  let q=parseFloat(document.getElementById('det-nq')?.value)||0;
  let v=parseFloat(document.getElementById('det-nv')?.value)||0;
  let el=document.getElementById('det-prev-line');
  if(el){if(q*v>0){el.style.display='block';el.textContent='Subtotal: '+fmt(q*v);}else el.style.display='none';}
}
function detAgregar(){
  let p=(document.getElementById('det-np')?.value||'').trim();
  let q=parseInt(document.getElementById('det-nq')?.value)||1;
  let v=parseFloat(document.getElementById('det-nv')?.value)||0;
  if(!p){toast('⚠️ Escribe el nombre del producto','info');return;}
  if(!v){toast('⚠️ Ingresa el valor','info');return;}
  detItems.push({p,q,v,id:Date.now()+Math.random()});
  document.getElementById('det-np').value='';
  document.getElementById('det-nq').value=1;
  document.getElementById('det-nv').value='';
  _renderDetalle();
  setTimeout(()=>document.getElementById('det-np')?.focus(),50);
}
function detEliminar(uid){
  detItems=detItems.filter(x=>x.id!==uid);
  _renderDetalle();
}
function detGuardar(){
  if(!detItems.length)return;
  let f=document.getElementById('det-fecha')?.value||today();
  detItems.forEach(x=>{
    db.movimientos.push({id:db.nmi++,clienteId:detClienteId,producto:x.p,cantidad:x.q,valorUnit:x.v,fecha:f,pagado:false,tipo:'individual'});
  });
  let total=detItems.reduce((s,x)=>s+x.q*x.v,0);
  let n=detItems.length;
  detItems=[];
  save(`Agregar ${n} producto${n!==1?'s':''}`);refreshAll();
  _renderDetalle();
  toast(`✓ ${n} producto${n!==1?'s':''} agregado${n!==1?'s':''} — ${fmt(total)}`);
}

