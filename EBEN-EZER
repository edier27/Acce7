function liquidar(id){
  let c=db.clientes.find(x=>x.id===id),movs=activos(id),total=deuda(id);
  document.getElementById('det-title').textContent='💳 Liquidar Cuenta';
  let items=movs.map(m=>`<div class="pitem"><div class="info"><div class="name">${m.producto} <button onclick="editarProductoModal(${m.id})" style="background:none;border:none;cursor:pointer;font-size:11px;color:var(--ink3);padding:1px 4px;border-radius:4px;" title="Editar producto">✏️</button></div><div class="meta">📅 ${fmtFechaHora(m.fecha)} &nbsp;·&nbsp; ×${m.cantidad} und &nbsp;·&nbsp; ${fmt(m.valorUnit)} c/u</div></div><div style="display:flex;align-items:center;gap:6px;"><div class="price">${fmt(m.valorUnit*m.cantidad)}</div><button onclick="eliminarProductoDeuda(${m.id})" style="background:none;border:none;cursor:pointer;color:var(--red);font-size:13px;padding:3px 5px;border-radius:5px;opacity:.7;" title="Eliminar">🗑️</button></div></div>`).join('');
  document.getElementById('det-body').innerHTML=`
    <div class="cmh"><div class="avatar-lg" style="background:${c.color}22;color:${c.color}">${ini(c.nombre)}</div><div><div class="cmh-name">${c.nombre}</div><div class="cmh-meta">Resumen de cuenta a liquidar</div></div></div>
    <div class="slabel">Productos Pendientes (${movs.length})</div>
    <div class="product-list-modal">${items}</div>
    <div class="total-row"><span class="label">💰 Total a Cobrar</span><span class="amount">${fmt(total)}</span></div>
    <div style="background:var(--surface2);border:1px solid var(--border2);border-radius:8px;padding:11px 13px;margin:10px 0;">
      <div style="font-size:12px;font-weight:700;color:var(--muted);text-transform:uppercase;letter-spacing:.5px;margin-bottom:8px;">💳 Abono Parcial (opcional)</div>
      <div style="display:flex;gap:8px;align-items:center;">
        <input class="form-input" id="liq-abono-val" type="number" min="0" max="${total}" placeholder="Valor del abono $" style="max-width:200px;" oninput="liqPrevAbono(${total})">
