// Buscar para liquidar
let regLiqClienteId=null;
function regBuscarClienteLiq(v){
  let res=document.getElementById('reg-cli-results-liq');
  if(!v||v.length<2){res.style.display='none';return;}
  let matches=db.clientes.filter(c=>c.nombre.toLowerCase().includes(v.toLowerCase())||c.telefono.includes(v));
  if(!matches.length){res.innerHTML='<div class="qs-result-item" style="color:var(--muted)">Sin resultados</div>';res.style.display='block';return;}
  res.innerHTML=matches.filter(c=>deuda(c.id)>0).map(c=>{let d=deuda(c.id);return`<div class="qs-result-item" onclick="regSeleccionarLiq(${c.id})">
    <div class="avatar" style="background:${c.color}22;color:${c.color};font-size:10px;margin:0;">${ini(c.nombre)}</div>
    <div style="flex:1"><div class="qs-result-name">${c.nombre}</div><div class="qs-result-meta">📞 ${c.telefono}</div></div>
    <div class="qs-result-debt" style="color:var(--accent)">${fmt(d)}</div>
  </div>`;}).join('')||'<div class="qs-result-item" style="color:var(--muted)">Sin clientes con deuda pendiente</div>';
  res.style.display='block';
}
function regSeleccionarLiq(id){
  regLiqClienteId=id;
  let c=db.clientes.find(x=>x.id===id);
  document.getElementById('reg-buscar-liq').value=c.nombre;
  document.getElementById('reg-cli-results-liq').style.display='none';
  _renderRegLiqDetalle(id);
}
function _renderRegLiqDetalle(id){
  let c=db.clientes.find(x=>x.id===id),movs=activos(id),total=deuda(id);
  let det=document.getElementById('reg-liq-detalle');
  if(!movs.length){
    let up=ultimoPago(id);
    det.style.display='block';
    det.innerHTML='<div class="empty-state" style="color:var(--green)">✅ Este cliente no tiene deuda pendiente'+(up?'<div style=\"font-size:12px;color:var(--muted);margin-top:6px;\">💚 Último pago: '+fmtFechaHora(up)+'</div>':'')+'</div>';
    return;
  }
  let items=movs.map((m,i)=>`<div class="pitem">
    <div style="margin-right:6px;"><input type="checkbox" id="chk-mov-${m.id}" style="width:auto;margin:0;" checked></div>
    <div class="info"><div class="name">${m.producto} <button onclick="editarNombreProducto(${m.id})" style="background:none;border:none;cursor:pointer;font-size:11px;color:var(--ink3);padding:1px 4px;border-radius:4px;" title="Editar nombre">✏️</button></div><div class="meta">📅 ${fmtFechaHora(m.fecha)} &nbsp;·&nbsp; ×${m.cantidad} und &nbsp;·&nbsp; ${fmt(m.valorUnit)} c/u</div></div>
    <div class="price">${fmt(m.valorUnit*m.cantidad)}</div>
    <button class="btn btn-xs btn-ghost" onclick="abonarDeudaIndividual(${id},${m.id})" title="Abonar solo esta deuda">💳</button>
  </div>`).join('');
  det.style.display='block';
  det.innerHTML=`
    <div class="cli-found-card" style="margin-bottom:12px;">
      <div class="avatar" style="background:${c.color}22;color:${c.color};font-size:12px;width:42px;height:42px;">${ini(c.nombre)}</div>
      <div><div class="cfc-name">${c.nombre}</div><div class="cfc-meta">📞 ${c.telefono}</div></div>
      <div class="cfc-deuda">${fmt(total)}</div>
      <button class="btn btn-xs btn-ghost" onclick="document.getElementById('reg-buscar-liq').value='';document.getElementById('reg-liq-detalle').style.display='none';">✕</button>
    </div>
    <div class="slabel">Productos pendientes — 💳 toca el ícono para abonar por deuda (${movs.length})</div>
    <div class="product-list-modal">${items}</div>
    <div class="total-row"><span class="label">💰 Total a Cobrar</span><span class="amount">${fmt(total)}</span></div>
    <div style="background:var(--surface2);border:1px solid var(--border2);border-radius:8px;padding:11px 13px;margin:10px 0;">
      <div style="font-size:12px;font-weight:700;color:var(--muted);text-transform:uppercase;letter-spacing:.5px;margin-bottom:8px;">💳 Abono Parcial (opcional)</div>
      <div style="display:flex;gap:8px;align-items:center;">
        <input class="form-input" id="reg-liq-abono-val" type="number" min="0" max="${total}" placeholder="Valor del abono $" style="max-width:200px;" oninput="regLiqPrevAbono(${total})">
        <span style="font-size:12px;color:var(--muted)">Deja vacío para pago total</span>
      </div>
      <div id="reg-liq-abono-prev" style="display:none;margin-top:6px;font-size:12px;color:var(--accent);font-weight:700;"></div>
    </div>
    <div class="form-actions">
      <button class="btn btn-ghost" onclick="imprimirCuenta(${id})">📄 PDF</button>
      <button class="btn btn-ghost" style="background:#25D366;color:#fff;border:none;" onclick="enviarWhatsApp(${id},'liquidar')">💬 Cobrar WA</button>
      <button class="btn btn-warning" onclick="(function(){let v=parseFloat(document.getElementById('reg-liq-abono-val')?.value)||0;if(!v||v<=0){toast('⚠️ Ingresa el valor del abono','info');return;}let c=db.clientes.find(x=>x.id===${id});let s=${total}-v;pedirConfirmAbono(c?.nombre||'',v,s,function(){regConfirmarAbono(${id},${total})});})()">💰 Abono Parcial</button>
      <button class="btn btn-success" onclick="pedirConfirmPagoTotal(${id},${total},${movs.length},function(){regConfirmarLiq(${id},${total},${movs.length})})">✓ Pago Total</button>
    </div>`;
}

function regLiqPrevAbono(total){
  let v=parseFloat(document.getElementById('reg-liq-abono-val')?.value)||0;
  let el=document.getElementById('reg-liq-abono-prev');
  if(!el)return;
  if(v>0&&v<total){el.style.display='block';el.textContent='Abono: '+fmt(v)+' — Saldo: '+fmt(total-v);}
  else if(v>=total){el.style.display='block';el.textContent='⚠️ Cubre deuda total. Usa "Pago Total".';}
  else el.style.display='none';
}

function regConfirmarAbono(id,total){
  let abono=parseFloat(document.getElementById('reg-liq-abono-val')?.value)||0;
  if(!abono||abono<=0){toast('⚠️ Ingresa el valor del abono','info');return;}
  if(abono>=total){if(!confirm('El abono cubre la deuda total. ¿Liquidar completamente?'))return;regConfirmarLiq(id,total,activos(id).length);return;}
  let c=db.clientes.find(x=>x.id===id);
  // Descontar el abono de los movimientos activos (del más antiguo al más nuevo)
  let movsPend=db.movimientos.filter(m=>m.clienteId===id&&!m.pagado).sort((a,b)=>new Date(a.fecha)-new Date(b.fecha));
  let restante=abono;
  let detalle=[];
  for(let m of movsPend){
    if(restante<=0)break;
    let subtotal=m.valorUnit*m.cantidad;
    if(restante>=subtotal){
      m.pagado=true;
      detalle.push({producto:m.producto,cantidad:m.cantidad,valorUnit:m.valorUnit,fecha:m.fecha});
      restante-=subtotal;
    } else {
      let pagoParcial=restante;
      let nuevoTotal=subtotal-pagoParcial;
      m.valorUnit=nuevoTotal/m.cantidad;
      detalle.push({producto:m.producto+' (abono)',cantidad:m.cantidad,valorUnit:pagoParcial/m.cantidad,fecha:m.fecha});
      restante=0;
    }
  }
  let saldo=deuda(id);
  db.liquidaciones.push({id:db.nli++,clienteId:id,fecha:nowDateTime(),valor:abono,productos:detalle.length,detalle,notas:'Abono parcial',tipo:'abono'});
  save(`Abono parcial ${c.nombre}: ${fmt(abono)}`);
  document.getElementById('reg-buscar-liq').value='';
  document.getElementById('reg-liq-detalle').style.display='none';
  _regLiqClienteId=null;
  refreshAll();
  toast(`✓ Abono ${fmt(abono)} para ${c.nombre} — Saldo: ${fmt(saldo)}`);
  let tel=formatearTelefono(c.telefono);
  if(tel){
    let fechaStr=new Date().toLocaleDateString('es-CO',{day:'2-digit',month:'long',year:'numeric'})+' '+new Date().toLocaleTimeString('es-CO',{hour:'2-digit',minute:'2-digit'});
    let msg=`*COMPROBANTE DE ABONO PARCIAL*\nTienda Eben-ezer\n\nHola ${c.nombre.split(' ')[0]}, registramos tu abono:\n\n*Abono recibido:* ${fmt(abono)}\n*Saldo pendiente:* ${fmt(saldo)}\n*Fecha:* ${fechaStr}\n\n🙏 _Tienda Eben-ezer_`;
    toastWA('✓ Abono registrado — ¿enviar comprobante?','https://wa.me/'+tel+'?text='+encodeURIComponent(msg));
  }
}

function abonarDeudaIndividual(clienteId,movId){
  let c=db.clientes.find(x=>x.id===clienteId);
  let m=db.movimientos.find(x=>x.id===movId);
  if(!c||!m)return;
  let valTotal=m.valorUnit*m.cantidad;
  let body=document.getElementById('abono-deuda-body');
  body.innerHTML=`
    <div class="cmh" style="margin-bottom:12px;">
      <div class="avatar-lg" style="background:${c.color}22;color:${c.color}">${ini(c.nombre)}</div>
      <div><div class="cmh-name">${c.nombre}</div><div class="cmh-meta">Abono a deuda específica</div></div>
    </div>
    <div class="orden-detail" style="background:var(--surface2);border:1px solid var(--border2);border-radius:8px;padding:12px;margin-bottom:12px;">
      <div style="font-weight:700;font-size:14px;margin-bottom:4px;">📦 ${m.producto}</div>
      <div style="font-size:12px;color:var(--muted);">📅 ${fmtFechaHora(m.fecha)} &nbsp;·&nbsp; ×${m.cantidad} und &nbsp;·&nbsp; ${fmt(m.valorUnit)} c/u</div>
      <div style="font-size:15px;font-weight:800;color:var(--accent);margin-top:6px;">Total: ${fmt(valTotal)}</div>
    </div>
    <div class="form-group"><label class="form-label">Valor del abono ($)</label>
      <input class="form-input" id="abd-valor" type="number" min="1" max="${valTotal}" placeholder="Valor a abonar" oninput="abdPrev(${valTotal})">
    </div>
    <div id="abd-prev" style="display:none;margin:6px 0;font-size:12px;color:var(--accent);font-weight:700;"></div>
    <div class="form-actions">
      <button class="btn btn-ghost" onclick="closeModal('m-abono-deuda')">Cancelar</button>
      <button class="btn btn-warning" onclick="(function(){let v=parseFloat(document.getElementById('abd-valor')?.value)||0;if(!v||v<=0){toast('⚠️ Ingresa el valor','info');return;}let c=db.clientes.find(x=>x.id===${clienteId});let s=${valTotal}-v;pedirConfirmAbono(c?.nombre||'',v,s,function(){confirmarAbonoDeuda(${clienteId},${movId},${valTotal},false)});})()">💰 Abono Parcial</button>
      <button class="btn btn-success" onclick="pedirConfirmPagoTotal(${clienteId},${valTotal},1,function(){confirmarAbonoDeuda(${clienteId},${movId},${valTotal},true)})">✓ Pagar Completo</button>
    </div>`;
  closeModal('m-det');
  openModal('m-abono-deuda');
}

function abdPrev(total){
  let v=parseFloat(document.getElementById('abd-valor')?.value)||0;
  let el=document.getElementById('abd-prev');
  if(!el)return;
  if(v>0&&v<total){el.style.display='block';el.textContent='Abono: '+fmt(v)+' — Saldo de esta deuda: '+fmt(total-v);}
  else el.style.display='none';
}

function confirmarAbonoDeuda(clienteId,movId,valTotal,completo){
  let c=db.clientes.find(x=>x.id===clienteId);
  let m=db.movimientos.find(x=>x.id===movId);
  if(!c||!m)return;
  let abono=completo?valTotal:(parseFloat(document.getElementById('abd-valor')?.value)||0);
  if(!abono||abono<=0){toast('⚠️ Ingresa el valor','info');return;}
  let saldo=valTotal-abono;
  if(completo||abono>=valTotal){
    m.pagado=true;
    db.liquidaciones.push({id:db.nli++,clienteId,fecha:nowDateTime(),valor:valTotal,productos:1,detalle:[{producto:m.producto,cantidad:m.cantidad,valorUnit:m.valorUnit,fecha:m.fecha}],notas:'Pago individual',tipo:'individual'});
    toast(`✓ "${m.producto}" pagado completo — ${fmt(valTotal)}`);
  } else {
    // Reducir el valorUnit del movimiento para reflejar el saldo real
    let nuevoTotal=valTotal-abono;
    m.valorUnit=nuevoTotal/m.cantidad;
    db.liquidaciones.push({id:db.nli++,clienteId,fecha:nowDateTime(),valor:abono,productos:0,detalle:[{producto:m.producto,cantidad:m.cantidad,valorUnit:m.valorUnit,fecha:m.fecha}],notas:`Abono parcial a: ${m.producto}`,tipo:'abono'});
    toast(`✓ Abono ${fmt(abono)} para "${m.producto}" — Saldo: ${fmt(Math.max(0,saldo))}`);
  }
  save(`Abono a deuda de ${c.nombre}`);
  closeModal('m-abono-deuda');
  refreshAll();
  let tel=formatearTelefono(c.telefono);
  if(tel){
    let fechaStr=new Date().toLocaleDateString('es-CO',{day:'2-digit',month:'long',year:'numeric'})+' '+new Date().toLocaleTimeString('es-CO',{hour:'2-digit',minute:'2-digit'});
    let tipoMsg=completo||abono>=valTotal?'PAGO COMPLETO':'ABONO PARCIAL';
    let saldoMsg=completo||abono>=valTotal?'¡Deuda cancelada! ✅':'Saldo pendiente de esta deuda: '+fmt(Math.max(0,saldo));
    // Sin número Nequi en comprobante de abono; en pago total sí se incluye
    let extraInfo='';
    // Nequi no se muestra en comprobantes de pago
    let msg=`*COMPROBANTE DE ${tipoMsg}*\nTienda Eben-ezer\n\nHola ${c.nombre.split(' ')[0]}:\n\n*Producto:* ${m.producto}\n*Valor pagado:* ${fmt(abono)}\n${saldoMsg}\n*Fecha:* ${fechaStr}${extraInfo}\n\n🙏 _Gracias por tu pago — Tienda Eben-ezer_`;
    toastWA('✓ Pago registrado — ¿enviar comprobante?','https://wa.me/'+tel+'?text='+encodeURIComponent(msg));
  }
}
function regConfirmarLiq(id,total,numProductos){
  let c=db.clientes.find(x=>x.id===id);
  let movsPagados=db.movimientos.filter(m=>m.clienteId===id&&!m.pagado);
  let detallePagado=movsPagados.map(m=>({producto:m.producto,cantidad:m.cantidad,valorUnit:m.valorUnit,fecha:m.fecha}));
  movsPagados.forEach(m=>m.pagado=true);
  let fechaLiq=nowDateTime();
  db.liquidaciones.push({id:db.nli++,clienteId:id,fecha:fechaLiq,valor:total,productos:numProductos,detalle:detallePagado,notas:'',tipo:'total'});
  save(`Liquidar cuenta de ${c.nombre}`);
  document.getElementById('reg-buscar-liq').value='';
  document.getElementById('reg-liq-detalle').style.display='none';
  toast(`✓ Cuenta de ${c.nombre} liquidada — ${fmt(total)}`);
  let tel=formatearTelefono(c.telefono);
  if(tel){
    let lista=detallePagado.map(p=>`• ${p.producto}${p.cantidad>1?' ×'+p.cantidad:''} = ${fmt(p.valorUnit*p.cantidad)}`).join('\n');
    let fechaStr=new Date().toLocaleDateString('es-CO',{day:'2-digit',month:'long',year:'numeric'})+' '+new Date().toLocaleTimeString('es-CO',{hour:'2-digit',minute:'2-digit'});
    let msg=`*COMPROBANTE DE PAGO TOTAL*\nTienda Eben-ezer\n\nHola ${c.nombre.split(' ')[0]}, confirmamos el pago total:\n\n*Productos pagados:*\n${lista}\n\n*Total cancelado: ${fmt(total)}*\n*Fecha:* ${fechaStr}\n\nGracias por tu pago.`;
    toastWA('✓ Cuenta liquidada — ¿enviar comprobante?','https://wa.me/'+tel+'?text='+encodeURIComponent(msg));
  }
}

// Buscar general
function regBuscarGeneral(v){
